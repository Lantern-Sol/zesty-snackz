{% liquid
  assign block_settings = block.settings
  assign size_px = block_settings.size | default: 120
  assign size_rem = size_px | divided_by: 16.0
  assign image_width = size_px | times: 3 | at_most: 1400
  assign sizes_attribute = size_px | append: 'px'

  assign peel_enabled = false
  if block_settings.peel_enabled and block_settings.peel_code != blank
    assign peel_enabled = true
  endif
%}

{%- capture sticker_image -%}
  {% if block_settings.image != blank %}
    {{
      block_settings.image
      | image_url: width: image_width
      | image_tag: loading: 'lazy', class: 'floating-sticker__media', sizes: sizes_attribute
    }}
  {% else %}
    {{ 'image' | placeholder_svg_tag: 'floating-sticker__media floating-sticker__media--placeholder' }}
  {% endif %}
{%- endcapture -%}

{% if peel_enabled %}
  <script
    src="{{ 'sticker-peel.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

<div
  class="floating-sticker{% if request.design_mode %} floating-sticker--design-mode{% endif %}{% if block_settings.shadow %} floating-sticker--shadow{% endif %}{% if peel_enabled %} floating-sticker--peelable{% endif %}"
  style="
    --sticker-x: {{ block_settings.x_position }};
    --sticker-y: {{ block_settings.y_position }}%;
    --sticker-size: {{ size_rem }}rem;
    --sticker-rotation: {{ block_settings.rotation | default: 0 }}deg;
    --sticker-offset: {{ block_settings.motion_offset | default: 0 }}s;
  "
  {{ block.shopify_attributes }}
>
  <div class="floating-sticker__floater">
    <div class="floating-sticker__rotor">
      {% if peel_enabled %}
        <sticker-peel class="floating-sticker__peel">
          <span class="floating-sticker__reveal">
            <button
              type="button"
              class="floating-sticker__code"
              data-peel-code="{{ block_settings.peel_code | escape }}"
              aria-label="Copy discount code {{ block_settings.peel_code | escape }}"
            >
              <span class="floating-sticker__code-label">{{ block_settings.peel_code | escape }}</span>
              <span class="floating-sticker__code-copied" aria-hidden="true">Copied!</span>
            </button>
          </span>
          <button
            type="button"
            class="floating-sticker__front"
            data-peel-trigger
            aria-expanded="false"
            aria-label="Peel the sticker to reveal a discount code"
          >
            {{ sticker_image }}
          </button>
          <span class="floating-sticker__flap" aria-hidden="true">
            {{ sticker_image }}
          </span>
        </sticker-peel>
      {% else %}
        {{ sticker_image }}
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .floating-sticker {
    position: absolute;
    top: var(--sticker-y, 50%);

    /* Percentages resolve against the sticker group, which spans the full section */
    left: calc(var(--sticker-x, 50) * 1%);

    /* Anchor the sticker at its center: X/Y position its middle. At the
       extremes the sticker may hang past the section edges; the section's
       overflow clipping handles it. */
    translate: -50% -50%;
    width: var(--sticker-size, 7.5rem);
    z-index: var(--layer-flat);
    pointer-events: none;
  }

  /* Keep the block clickable in the theme editor so it can be selected on canvas */
  .floating-sticker--design-mode,
  .floating-sticker--peelable {
    pointer-events: auto;
  }

  /* The bob animates `translate` on an unrotated wrapper so the sticker always
     drifts straight up and down; the wobble is purely visual on the rotor
     inside. Separate elements, separate properties — the two loops compose. */
  .floating-sticker__floater {
    animation: floating-sticker-bob 2.9s ease-in-out calc(-1 * var(--sticker-offset, 0s)) infinite;
  }

  /* drop-shadow instead of box-shadow so the shadow follows the sticker's alpha
     silhouette (not its rectangle). On the floater, not the rotated rotor, so
     the shadow always drops downward in screen space */
  .floating-sticker--shadow .floating-sticker__floater {
    filter: drop-shadow(0 18px 24px rgb(11 27 43 / 0.18));
  }

  /* Base rotation from the setting plus an animated wobble offset. The rotor
     carries the rotation (rather than the media) so the peel layers and the
     revealed code all turn together as one piece. */
  .floating-sticker__rotor {
    rotate: calc(var(--sticker-rotation, 0deg) + var(--floating-sticker-wobble, 0deg));
    animation: floating-sticker-wobble 3.2s ease-in-out calc(-1 * var(--sticker-offset, 0s)) infinite;
  }

  .floating-sticker__media {
    display: block;
    width: 100%;
    height: auto;
  }

  .floating-sticker__media--placeholder {
    aspect-ratio: 1;
  }

  /* ---- Peel-to-reveal easter egg ----------------------------------------
     One animatable fraction (--sticker-peel) drives the whole effect: the
     fold line sits at (1 - peel) of the sticker's height, the front layer is
     clipped away below it, and a mirrored copy of the image — the sticker's
     underside — folds over to occupy the band just above it. Hover teases
     the fold open; clicking holds it open. */

  /* Registered so the peel fraction transitions smoothly; inherits so the
     front/flap/reveal children can derive their clip-paths from it */
  @property --sticker-peel {
    syntax: '<number>';
    initial-value: 0;
    inherits: true;
  }

  .floating-sticker__peel {
    --sticker-peel: 0;

    position: relative;
    display: block;
    transition: --sticker-peel 0.55s cubic-bezier(0.25, 1, 0.4, 1);
  }

  .floating-sticker__peel:hover {
    --sticker-peel: 0.16;
  }

  /* After :hover so a held-open sticker stays fully open while hovered */
  .floating-sticker__peel.is-peeled {
    --sticker-peel: 0.62;
  }

  /* While dragging, the component writes --sticker-peel inline every frame;
     the transition would lag the pointer, so suspend it */
  .floating-sticker__peel.is-dragging {
    transition: none;
  }

  /* The front of the sticker, clipped away below the fold line. clip-path
     also clips the button's hit area, so once peeled the code underneath
     becomes clickable through the opened region. */
  .floating-sticker__front {
    display: block;
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    appearance: none;
    cursor: grab;

    /* The drag drives the peel, so keep touch drags for ourselves instead of
       scrolling the page, and suppress native image dragging/selection */
    touch-action: none;
    clip-path: inset(0 0 calc(var(--sticker-peel) * 100%) 0);
  }

  .floating-sticker__peel.is-dragging .floating-sticker__front {
    cursor: grabbing;
  }

  .floating-sticker__front .floating-sticker__media {
    user-select: none;
    -webkit-user-drag: none;
  }

  /* The underside: a mirrored copy of the image, flipped about its bottom
     edge and pulled up so the strip just below the fold (in its own,
     pre-transform coordinates) lands seamlessly in the band just above the
     fold. Clipped to a thin strip — a tight curl — rather than the full
     folded-over flap: a true fold grows at twice the peel distance and would
     bury the sticker's face past a half peel. The curl grows with the peel
     up to a cap (min()), and the max() keeps the strip inside the image while
     the peel is still smaller than the cap. Brightened and desaturated to
     read as the sticker's backing; the local upward drop-shadow flips to
     fall onto the front below the curl. */
  .floating-sticker__flap {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    clip-path: inset(
      calc(100% - var(--sticker-peel) * 100%)
      0
      max(0%, calc(var(--sticker-peel) * 100% - min(var(--sticker-peel) * 60%, 14%)))
      0
    );
    transform: translateY(calc(var(--sticker-peel) * -200%)) scaleY(-1);
    transform-origin: bottom;
    filter: brightness(1.7) saturate(0.35) drop-shadow(0 -6px 8px rgb(11 27 43 / 0.25));
  }

  /* The prize behind the sticker. Clipped to the peeled-away band — the
     sticker images are die-cut with alpha, so without this clip the code
     would show through the transparent parts while the sticker is closed. */
  .floating-sticker__reveal {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    visibility: hidden;
    clip-path: inset(calc(100% - var(--sticker-peel) * 100%) 0 0 0);

    /* Delay hiding until the flap has folded back down */
    transition: visibility 0s 0.45s;
  }

  /* is-dragging included because touch drags never set :hover */
  .floating-sticker__peel:hover .floating-sticker__reveal,
  .floating-sticker__peel.is-dragging .floating-sticker__reveal,
  .floating-sticker__peel.is-peeled .floating-sticker__reveal {
    visibility: visible;
    transition: visibility 0s;
  }

  .floating-sticker__code {
    font-family: var(--font-heading--family);
    font-size: calc(var(--sticker-size, 7.5rem) / 9);
    letter-spacing: 0.06em;
    white-space: nowrap;
    color: var(--color-secondary-button-text, var(--color-foreground));
    background: var(--color-secondary-button-background, var(--color-background));
    border: 2px dashed var(--color-secondary-button-border, currentcolor);
    border-radius: 0.5em;
    padding: 0.3em 0.65em;
    cursor: pointer;
  }

  .floating-sticker__code:hover {
    color: var(--color-secondary-button-hover-text, var(--color-foreground));
    background: var(--color-secondary-button-hover-background, var(--color-background));
    border-color: var(--color-secondary-button-hover-border, currentcolor);
  }

  .floating-sticker__code-copied {
    display: none;
  }

  .floating-sticker__code.is-copied .floating-sticker__code-label {
    display: none;
  }

  .floating-sticker__code.is-copied .floating-sticker__code-copied {
    display: inline;
  }

  /* Registered so the wobble offset interpolates smoothly instead of stepping */
  @property --floating-sticker-wobble {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  /* Gentle pendulum around the resting angle, traced from the source export
     (±0.043rad ≈ ±2.5deg). 3.2s against the 2.9s bob so the combined motion
     drifts out of phase instead of ticking like a metronome */
  @keyframes floating-sticker-wobble {
    0%,
    50%,
    100% {
      --floating-sticker-wobble: 0deg;
    }

    25% {
      --floating-sticker-wobble: 2.5deg;
    }

    75% {
      --floating-sticker-wobble: -2.5deg;
    }
  }

  /* Vertical drift traced from the source export: rise first, sink past the
     resting point, return — ±11px per cycle */
  @keyframes floating-sticker-bob {
    0%,
    50%,
    100% {
      translate: 0 0;
    }

    25% {
      translate: 0 -11px;
    }

    75% {
      translate: 0 11px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-sticker__floater,
    .floating-sticker__rotor {
      animation: none;
    }

    .floating-sticker__peel {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Floating sticker",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:settings.image"
    },
    {
      "type": "number",
      "id": "size",
      "label": "t:settings.width",
      "default": 120,
      "info": "Width in pixels."
    },
    {
      "type": "range",
      "id": "rotation",
      "label": "Rotation",
      "min": -180,
      "max": 180,
      "step": 5,
      "unit": "deg",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "shadow",
      "label": "Shadow",
      "default": true
    },
    {
      "type": "header",
      "content": "t:settings.position"
    },
    {
      "type": "range",
      "id": "x_position",
      "label": "Horizontal position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "y_position",
      "label": "Vertical position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "t:settings.animation"
    },
    {
      "type": "range",
      "id": "motion_offset",
      "label": "Motion offset",
      "min": 0,
      "max": 3,
      "step": 0.1,
      "unit": "s",
      "default": 0,
      "info": "Staggers the float loop so neighboring stickers don't move in sync."
    },
    {
      "type": "header",
      "content": "Peel effect"
    },
    {
      "type": "checkbox",
      "id": "peel_enabled",
      "label": "Peel to reveal",
      "default": false,
      "info": "Hovering teases the sticker's edge; dragging or clicking peels it open."
    },
    {
      "type": "text",
      "id": "peel_code",
      "label": "Discount code",
      "info": "Hidden behind the sticker. Clicking the revealed code copies it. Leave empty to disable the peel."
    }
  ],
  "presets": [
    {
      "name": "Floating sticker",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
