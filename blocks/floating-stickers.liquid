<div
  class="floating-stickers{% if block.settings.full_width %} floating-stickers--full-width{% endif %}{% if block.settings.behind %} floating-stickers--behind{% endif %}"
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}
</div>

{% stylesheet %}
  .floating-stickers {
    /* Distance from the viewport edge to the page-width central column */
    --floating-edge-offset: calc(var(--page-margin) + max((100vw - var(--page-width)) / 2, 0px));

    position: absolute;
    inset: 0;
    z-index: var(--layer-flat);

    /* The group is a pure positioning layer; the stickers inside re-enable
       pointer events in the theme editor for on-canvas selection */
    pointer-events: none;
  }

  /* Behind-content option: drop the overlay below the section's content
     (--layer-lowest) instead of above it (--layer-flat). Still sits above the
     section background (--layer-section-background), so the elements show
     through the gaps between content rather than covering it. */
  .floating-stickers--behind {
    z-index: var(--layer-lowest);
  }

  /* Stickers near the edges intentionally overhang the group into the page
     margins, so clip at the section (which spans the full page width) —
     otherwise they widen the page's horizontal scroll area. Only the x axis:
     vertical overhang must stay visible. `clip` not `hidden`, so no scroll
     container is created. */
  .section:has(.floating-stickers) {
    overflow-x: clip;
  }

  /* When the section constrains its content to page width, stretch the group
     to the full section width so the stickers inside position against it */
  @media screen and (min-width: 750px) {
    .section-content-wrapper.page-width > .floating-stickers {
      left: calc(-1 * var(--floating-edge-offset));
      right: calc(-1 * var(--floating-edge-offset));
    }
  }

  @media screen and (max-width: 749px) {
    .section-content-wrapper.page-width-mobile > .floating-stickers {
      left: calc(-1 * var(--floating-edge-offset));
      right: calc(-1 * var(--floating-edge-offset));
    }
  }

  /* Full-width option: break the overlay out of the section's content column so
     it spans the whole viewport, letting stickers be placed across the full
     screen no matter how narrow the section is. `calc(-50vw + 50%)` puts the
     left edge at the viewport edge for a centred wrapper. The compound selector
     matches the page-width rules' specificity and comes later, so it wins for
     full-width groups; the plainer selector covers non-page-width wrappers. */
  .section-content-wrapper > .floating-stickers--full-width,
  .section-content-wrapper.page-width > .floating-stickers--full-width,
  .section-content-wrapper.page-width-mobile > .floating-stickers--full-width {
    left: calc(-50vw + 50%);
    right: auto;
    width: 100vw;
  }

  /* Sections apply their spacing on a container above the content wrapper, so
     the wrapper starts below the section's top padding — and, for the first
     section under a transparent header, below the header-height offset too.
     The spacing-style variables inherit, so pull the group back over them to
     span the true section bounds. Skipped when the wrapper carries
     spacing-style itself (e.g. the Custom Section), where inset: 0 already
     covers the padding area. */
  .section-content-wrapper:not(.spacing-style) > .floating-stickers {
    top: calc(-1 * var(--padding-block-start, 0px) - var(--section-top-offset, 0px));
    bottom: calc(-1 * var(--padding-block-end, 0px));
  }

  @media screen and (max-width: 749px) {
    .section-content-wrapper:not(.spacing-style) > .floating-stickers {
      top: calc(-1 * var(--padding-block-start-mobile, var(--padding-block-start, 0px)) - var(--section-top-offset, 0px));
      bottom: calc(-1 * var(--padding-block-end-mobile, var(--padding-block-end, 0px)));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Floating elements",
  "tag": null,
  "blocks": [
    {
      "type": "_floating-sticker"
    },
    {
      "type": "_wave-marquee"
    },
    {
      "type": "_wave-background"
    },
    {
      "type": "_confetti"
    }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Overlay layer that holds floating elements. It spans the full section, and the elements inside position relative to it."
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false,
      "info": "Stretch the overlay to the full screen width instead of the section's content width, so elements can be placed edge to edge."
    },
    {
      "type": "checkbox",
      "id": "behind",
      "label": "Behind content",
      "default": false,
      "info": "Place the overlay behind the section's content instead of in front of it."
    }
  ],
  "presets": [
    {
      "name": "Floating elements",
      "category": "t:categories.basic",
      "blocks": {
        "floating-sticker-1": {
          "type": "_floating-sticker"
        }
      },
      "block_order": ["floating-sticker-1"]
    }
  ]
}
{% endschema %}
