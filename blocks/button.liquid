{% render 'button', link: block.settings.link %}

{% schema %}
{
  "name": "t:names.button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label",
      "default": "t:text_defaults.button_label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "t:settings.style",
      "options": [
        {
          "value": "button",
          "label": "t:options.primary"
        },
        {
          "value": "button-secondary",
          "label": "t:options.secondary"
        },
        {
          "value": "button-unstyled",
          "label": "t:options.link"
        },
        {
          "value": "button-custom",
          "label": "t:options.custom"
        }
      ],
      "default": "button",
      "info": "t:info.edit_button_style_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.button_colors",
      "visible_if": "{{ block.settings.style_class == \"button-custom\" }}"
    },
    {
      "type": "color",
      "id": "custom_button_background",
      "label": "t:settings.background",
      "default": "{{ settings.color_palette.foreground }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "color",
      "id": "custom_button_text",
      "label": "t:settings.text",
      "default": "{{ settings.color_palette.background }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "checkbox",
      "id": "custom_button_shadow_enabled",
      "label": "Enable shadow",
      "default": false,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "range",
      "id": "custom_button_shadow_horizontal_offset",
      "label": "Horizontal offset",
      "min": -20,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_shadow_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_button_shadow_vertical_offset",
      "label": "Vertical offset",
      "min": -20,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_shadow_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_button_shadow_blur_radius",
      "label": "Blur radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_shadow_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_button_shadow_spread_radius",
      "label": "Spread radius",
      "min": -20,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_shadow_enabled }}"
    },
    {
      "type": "color",
      "id": "custom_button_shadow_color",
      "label": "Shadow color",
      "info": "Leave empty for the default shadow color",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_shadow_enabled }}"
    },
    {
      "type": "checkbox",
      "id": "custom_button_border_enabled",
      "label": "Override border",
      "default": false,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "color",
      "id": "custom_button_border",
      "label": "t:settings.borders",
      "default": "{{ settings.color_palette.background }}",
      "alpha": true,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_border_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_button_border_width",
      "label": "t:settings.border_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_border_enabled }}"
    },
    {
      "type": "checkbox",
      "id": "custom_button_padding_enabled",
      "label": "Override padding",
      "default": false,
      "visible_if": "{{ block.settings.style_class == 'button-custom' }}"
    },
    {
      "type": "range",
      "id": "custom_button_padding_block_start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_button_padding_block_end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_button_padding_inline_start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_button_padding_inline_end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled }}"
    },
    {
      "type": "checkbox",
      "id": "custom_button_use_mobile_padding",
      "label": "Use mobile padding",
      "default": false,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_button_padding_block_start_mobile",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled and block.settings.custom_button_use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "custom_button_padding_block_end_mobile",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled and block.settings.custom_button_use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "custom_button_padding_inline_start_mobile",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled and block.settings.custom_button_use_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "custom_button_padding_inline_end_mobile",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24,
      "visible_if": "{{ block.settings.style_class == 'button-custom' and block.settings.custom_button_padding_enabled and block.settings.custom_button_use_mobile_padding }}"
    },
    {
      "type": "color",
      "id": "link_text_color",
      "label": "t:settings.link_text_color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.style_class == 'button-unstyled' }}"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "checkbox",
      "id": "custom_text_enabled",
      "label": "Override text",
      "default": false
    },
    {
      "type": "range",
      "id": "custom_text_size",
      "label": "Font size",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.custom_text_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_text_line_height",
      "label": "Line height",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "default": 1.2,
      "visible_if": "{{ block.settings.custom_text_enabled }}"
    },
    {
      "type": "checkbox",
      "id": "custom_text_use_mobile",
      "label": "Use mobile text size",
      "default": false,
      "visible_if": "{{ block.settings.custom_text_enabled }}"
    },
    {
      "type": "range",
      "id": "custom_text_size_mobile",
      "label": "Font size (mobile)",
      "min": 8,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16,
      "visible_if": "{{ block.settings.custom_text_enabled and block.settings.custom_text_use_mobile }}"
    },
    {
      "type": "range",
      "id": "custom_text_line_height_mobile",
      "label": "Line height (mobile)",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "default": 1.2,
      "visible_if": "{{ block.settings.custom_text_enabled and block.settings.custom_text_use_mobile }}"
    },
    {
      "type": "range",
      "id": "rotation",
      "label": "Rotation",
      "min": -45,
      "max": 45,
      "step": 1,
      "unit": "deg",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == \"custom\" }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == \"custom\" }}"
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_on_desktop",
      "label": "Hide on desktop",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:names.button",
      "category": "t:categories.basic",
      "settings": {
        "link": "shopify://collections/all"
      }
    }
  ]
}
{% endschema %}
