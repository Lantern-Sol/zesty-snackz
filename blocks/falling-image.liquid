{% liquid
  assign block_settings = block.settings
  assign size_px = block_settings.size | remove: 'rem' | times: 16.0 | round
  assign image_width = size_px | times: 3 | at_most: 1400
  assign sizes_attribute = size_px | append: 'px'
%}

<div
  class="falling-image{% if request.design_mode %} falling-image--design-mode{% endif %}"
  style="
    --falling-x: {{ block_settings.x_position }}%;
    --falling-y: {{ block_settings.y_position }}%;
    --falling-size: {{ block_settings.size }};
    --falling-duration: {{ block_settings.duration }}s;
  "
  {{ block.shopify_attributes }}
>
  {% if block_settings.image != blank %}
    {{
      block_settings.image
      | image_url: width: image_width
      | image_tag: loading: 'lazy', class: 'falling-image__media', sizes: sizes_attribute
    }}
  {% else %}
    {{ 'image' | placeholder_svg_tag: 'falling-image__media falling-image__media--placeholder' }}
  {% endif %}
</div>

{% stylesheet %}
  .falling-image {
    position: absolute;
    top: var(--falling-y, 50%);
    left: var(--falling-x, 50%);

    /* Own-size compensation maps 0% -> flush with the start edge and 100% -> flush with the end edge */
    translate: calc(-1 * var(--falling-x, 50%)) calc(-1 * var(--falling-y, 50%));
    width: var(--falling-size, 7.5rem);
    z-index: var(--layer-flat);
    pointer-events: none;
  }

  /* Keep the block clickable in the theme editor so it can be selected on canvas */
  .falling-image--design-mode {
    pointer-events: auto;
  }

  .falling-image__media {
    display: block;
    width: 100%;
    height: auto;
    animation:
      falling-image-fall var(--falling-duration, 2s) var(--animation-timing-bounce) both,
      falling-image-float 3.5s ease-in-out var(--falling-duration, 2s) infinite;
  }

  .falling-image__media--placeholder {
    aspect-ratio: 1;
  }

  @keyframes falling-image-fall {
    from {
      transform: translateY(-100vh);
    }

    to {
      transform: translateY(0);
    }
  }

  @keyframes falling-image-float {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-6%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .falling-image__media {
      animation: none;
    }
  }
{% endstylesheet %}

