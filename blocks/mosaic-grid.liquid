            "row_span": 1,
            "background_color": "#1a9bd7",
            "padding-block-start": 24,
            "padding-block-end": 24,
            "padding-inline-start": 24,
            "padding-inline-end": 24,
            "border_radius": 16
          },
          "blocks": {
            "text": {
              "type": "text",
              "settings": {
                "text": "<h4>One</h4>"
              }
            }
          },
          "block_order": ["text"]
        },
        "cell_2": {
          "type": "_mosaic-cell",
          "settings": {
            "col_span": 1,
            "row_span": 1,
            "background_color": "#f4c430",
            "padding-block-start": 24,
            "padding-block-end": 24,
            "padding-inline-start": 24,
            "padding-inline-end": 24,
            "border_radius": 16
          },
          "blocks": {
            "text": {
              "type": "text",
              "settings": {
                "text": "<h4>Two</h4>"
              }
            }
          },
          "block_order": ["text"]
        },
        "cell_3": {
          "type": "_mosaic-cell",
          "settings": {
            "col_span": 1,
            "row_span": 2,
            "background_color": "#12233b",
            "padding-block-start": 24,
            "padding-block-end": 24,
            "padding-inline-start": 24,
            "padding-inline-end": 24,
            "border_radius": 16
          },
          "blocks": {
            "text": {
              "type": "text",
              "settings": {
                "text": "<h4>Three — tall</h4>"
              }
            }
          },
          "block_order": ["text"]
        },
        "cell_4": {
          "type": "_mosaic-cell",
          "settings": {
            "col_span": 2,
            "row_span": 1,
            "background_color": "#f4a6c0",
            "padding-block-start": 24,
            "padding-block-end": 24,
            "padding-inline-start": 24,
            "padding-inline-end": 24,
            "border_radius": 16
          },
          "blocks": {
            "text": {
              "type": "text",
              "settings": {
                "text": "<h4>Four — wide</h4>"
              }
            }
          },
          "block_order": ["text"]
        }
      },
      "block_order": ["cell_1", "cell_2", "cell_3", "cell_4"]
    }
  ]
}
{% endschema %}
