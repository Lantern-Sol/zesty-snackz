{% liquid
  assign product = closest.product
  assign has_applied_colour_filter = false
  assign filters_to_check = collection.filters | default: search.filters

  for filter in filters_to_check
    if filter.type == 'list' and filter.param_name contains 'color' and filter.active_values.size > 0
      assign has_applied_colour_filter = true
      break
    endif
  endfor

  assign hover_tagline = product.metafields.custom.card_hover_tagline.value
  assign hover_background = product.metafields.custom.card_hover_background.value
  assign hover_icon = product.metafields.custom.card_hover_icon.value
  assign sour_level = product.metafields.custom.sour_level.value
  assign card_badge = product.metafields.custom.card_badge.value
  assign show_hover_panel = false
  if block.settings.show_hover_label and hover_tagline != blank
    assign show_hover_panel = true
  endif
%}

{% capture children %}
  {% unless product == blank %}
    {%- if show_hover_panel -%}
      <div
        class="card-hover-panel"
        style="{% if hover_background != blank %}--card-hover-bg: {{ hover_background }};{% endif %}"
        aria-hidden="true"
      >
        {%- if hover_icon != blank -%}
          <div class="card-hover-panel__icon">
            {{ hover_icon | image_url: width: 80 | image_tag: loading: 'lazy', width: 40, height: 40, alt: '' }}
          </div>
        {%- endif -%}
        <p class="card-hover-panel__tagline">{{ hover_tagline }}</p>
      </div>
    {%- endif -%}
    {%- if sour_level != blank and sour_level > 0 -%}
      <div class="sour-meter" aria-label="{{ 'content.sour_level' | t: level: sour_level }}">
        <span class="sour-meter__label">{{ 'content.sour_label' | t }}</span>
        <span class="sour-meter__dots" aria-hidden="true">
          {%- for i in (1..4) -%}
            <span class="sour-meter__dot{% if i <= sour_level %} sour-meter__dot--filled{% endif %}"></span>
          {%- endfor -%}
        </span>
      </div>
    {%- endif -%}
    <div
      class="product-badges product-badges--{{ settings.badge_position }}"
      style="
        --badge-border-radius: {{ settings.badge_corner_radius }}px;
        --badge-font-family: var(--font-{{ settings.badge_font_family }}--family); --badge-font-weight: var(--font-{{ settings.badge_font_family }}--weight); --badge-text-transform: {{ settings.badge_text_transform }};
      "
    >
      {%- if card_badge != blank -%}
        <div class="product-badges__badge product-badges__badge--rectangle product-badges__badge--{{ card_badge | handleize }}">
          {{ card_badge }}
        </div>
      {%- endif -%}
      {%- if product.compare_at_price > product.price and product.available -%}
        <div class="product-badges__badge product-badges__badge--rectangle color-custom-badge-sale">
          {{ 'content.product_badge_sale' | t }}
        </div>
      {%- endif -%}
    </div>
    {%- if product.available == false -%}
      <div class="sold-out-stamp">{{ 'content.product_badge_sold_out' | t }}</div>
    {%- endif -%}
    {%- if block.settings.show_overlay_quick_add and settings.quick_add or block.settings.show_overlay_quick_add and settings.mobile_quick_add -%}
      {% render 'quick-add', product: product, section_id: section.id %}
    {%- endif -%}
  {% endunless %}
{% endcapture %}

{% render 'card-gallery', children: children %}

{% # Title and price for the zoomed out grid view %}
<div class="product-grid-view-zoom-out--details">
  {% if product == blank %}
    <h3 class="h4">{{ 'content.product_card_placeholder' | t }}</h3>
  {% else %}
    <h3 class="h4">{{ product.title }}</h3>
  {% endif %}
</div>

{% render 'product-badges-styles' %}

{% stylesheet %}
  .card-hover-panel {
    position: absolute;
    inset: 0;
    z-index: calc(var(--layer-flat) - 1);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--padding-md);
    padding: var(--padding-lg);
    background: var(--card-hover-bg, var(--color-foreground));
    color: var(--color-background);
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .product-card:hover .card-hover-panel,
  .product-card:focus-within .card-hover-panel {
    opacity: 1;
  }

  .card-hover-panel__icon img {
    width: 1.5625rem;
    height: auto;
    display: block;
  }

  .card-hover-panel__tagline {
    margin: 0;
    font-family: var(--font-body--family);
    font-weight: var(--font-body--weight);
    font-size: var(--font-size--xl);
    line-height: normal;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    max-width: 16.25rem;

    @media only screen and (max-width: 749px) {
      font-size: var(--font-size--md);
    }
  }

  @media (hover: none) {
    .card-hover-panel {
      display: none;
    }
  }
  slideshow-slide.product-media-container.product-media-container--image {
    background-color: var(--card-media-background, var(--color-background, transparent));
  }

  .sour-meter {
    position: absolute;
    top: var(--padding-sm);
    left: var(--padding-sm);
    z-index: var(--layer-flat);
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    padding: 0.25rem 0.625rem;
    background-color: var(--card-accent, var(--color-foreground));
    border-radius: 100px;
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.08);
  }

  .sour-meter__label {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 0.625rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(255 255 255);
    line-height: 1;
  }

  .sour-meter__dots {
    display: inline-flex;
    align-items: center;
    gap: 0.1875rem;
  }

  .sour-meter__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: 1.5px solid rgb(255 255 255);
  }

  .sour-meter__dot--filled {
    background-color: rgb(255 255 255);
  }

  .sold-out-stamp {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: var(--layer-flat);
    transform: translate(-50%, -50%) rotate(-8deg);
    padding: 0.375rem 1rem;
    background-color: #e8291c;
    border: 3px solid var(--color-background);
    border-radius: 0.5rem;
    box-shadow: 0 4px 12px rgb(0 0 0 / 0.25);
    color: rgb(255 255 255);
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-size--2xl);
    line-height: 1.1;
    text-transform: uppercase;
    white-space: nowrap;
    pointer-events: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_image",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_media"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "portrait",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted"
    },
    {
      "type": "checkbox",
      "id": "show_hover_label",
      "label": "Show hover label (category metafield)",
      "info": "On hover, replaces the image with the product's card_hover_background, card_hover_icon, and card_hover_tagline custom metafields. Requires these metafields to be set on the product.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_overlay_quick_add",
      "label": "Show quick-add over media",
      "info": "Turn off if you're using the separate Quick add block elsewhere on the card. Requires the theme-wide Quick add setting to be enabled.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_hover_arrows",
      "label": "Show slideshow arrows on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:settings.color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card_media",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
