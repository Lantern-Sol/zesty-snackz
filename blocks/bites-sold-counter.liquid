{%- doc -%}
  Renders the shop's Bites Sold counter from the custom.bites_sold shop
  metafield, kept up to date by the "Bites sold counter" Shopify Flow.
  Reuses the text snippet so it inherits all standard text block styling.
{%- enddoc -%}

{% liquid
  assign count = shop.metafields.custom.bites_sold.value
  if count == blank
    assign count = block.settings.fallback_count
  endif
  assign tag = block.settings.heading_tag | default: 'h1'
  capture count_html
    echo '<' | append: tag | append: '>' | append: count | append: '</' | append: tag | append: '>'
  endcapture
%}

{% render 'text', block: block, fallback_text: count_html %}

