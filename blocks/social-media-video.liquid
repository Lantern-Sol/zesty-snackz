{% assign block_settings = block.settings %}

{%- liquid
  # Resolve the desktop aspect-ratio. A user override (anything other than
  # 'auto') wins over the source-derived default.
  if block_settings.aspect_ratio != blank and block_settings.aspect_ratio != 'auto'
    assign resolved_aspect_ratio = block_settings.aspect_ratio
  elsif block_settings.source == 'uploaded'
    assign resolved_aspect_ratio = block_settings.video.aspect_ratio | default: 'auto'
  else
    assign resolved_aspect_ratio = 'auto'
  endif
-%}

{% capture video_style %}
   --size-style-width: 100%; --size-style-height: 100%;
   --size-style-aspect-ratio: {{ resolved_aspect_ratio }};
   {% if block_settings.aspect_ratio_mobile != blank %}--size-style-aspect-ratio-mobile: {{ block_settings.aspect_ratio_mobile }};{% endif %}
{% endcapture %}

{% capture card_style %}
  {% render 'spacing-style', settings: block_settings %}
  {% render 'border-override', settings: block_settings %}
  --size-style-width: {{ block_settings.custom_width }}%; --size-style-width-mobile: {{ block_settings.custom_width_mobile }}%;
{% endcapture %}

<div
  class="social-video-card spacing-style size-style border-style"
  style="{{ card_style }}"
  {{ block.shopify_attributes }}
>
  <div class="social-video-card__media">
    {% if block_settings.account != blank %}
      <span class="social-video-card__account">{{ block_settings.account }}</span>
    {% endif %}

    {% if block_settings.source == 'uploaded' %}
      {% render 'video',
        video: block_settings.video,
        video_class: 'social-video-card__player size-style',
        video_loop: block_settings.video_loop,
        video_style: video_style,
        video_preview_image: block_settings.video.preview_image
      %}
    {% else %}
      {% render 'video',
        video_from_url: true,
        video: block_settings.video_url.id,
        video_class: 'social-video-card__player size-style',
        video_type: block_settings.video_url.type,
        video_style: video_style,
        video_alt: block_settings.alt,
        video_preview_image: block_settings.cover_image
      %}
    {% endif %}

    {% if block_settings.heading != blank or block_settings.description != blank %}
      <div class="social-video-card__content">
        {% if block_settings.heading != blank %}
          <h6 class="social-video-card__heading">{{ block_settings.heading }}</h6>
        {% endif %}
        {% if block_settings.description != blank %}
          <div class="social-video-card__description">{{ block_settings.description }}</div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .placeholder-video {
    aspect-ratio: 5 / 3;
  }

  .social-video-card {
    display: flex;
    flex-direction: column;
    width: var(--size-style-width, 100%);
  }

  @media screen and (max-width: 749px) {
    .social-video-card {
      width: var(--size-style-width-mobile, var(--size-style-width, 100%));
    }
  }

  /* Media wrapper is the positioning context for the account chip. */
  .social-video-card__media {
    position: relative;
  }

  /* Apply the aspect ratio to the <deferred-media> container itself, not
     only the inner img/video. base.css's .size-style sets height: 100%,
     which would otherwise win over aspect-ratio. */
  .social-video-card__media deferred-media[style*='--size-style-aspect-ratio'] {
    aspect-ratio: var(--size-style-aspect-ratio, auto);
    height: auto;
  }

  /* Cover-fit any video/image content so a forced aspect ratio fills the box
     without letterboxing. */
  .social-video-card__media deferred-media video,
  .social-video-card__media deferred-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Account chip: brand blue over a translucent navy background, pinned to the
     top-left of the media. */
  .social-video-card__account {
    position: absolute;
    top: 12px;
    left: 14px;
    z-index: 2;
    color: #009eed;
    background: rgba(11, 27, 43, 0.78);
    padding: 6px 14px;
    border-radius: 999px;
    font-family: var(--font-body--family);
    font-size: var(--font-paragraph--size);
    line-height: 1;
    white-space: nowrap;
  }

  /* Heading + description block: overlaid on the bottom of the video, inset
     14px from the edges, no gap between the two lines. */
  .social-video-card__content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 40px 14px 14px;
    background: linear-gradient(180deg, rgba(11, 27, 43, 0.00) 0%, rgba(11, 27, 43, 0.85) 100%);
  }

  /* Heading uses the theme's H6 preset. */
  .social-video-card__heading {
    margin: 0;
    font-family: var(--font-h6--family);
    font-style: var(--font-h6--style);
    font-weight: var(--font-h6--weight);
    font-size: var(--font-h6--size);
    line-height: var(--font-h6--line-height);
    letter-spacing: var(--font-h6--letter-spacing);
    text-transform: var(--font-h6--case);
  }

  /* Description uses standard body typography in brand light-blue. */
  .social-video-card__description {
    margin: 0;
    color: #9fcbe4;
    font-family: var(--font-body--family);
    font-style: var(--font-body--style);
    font-weight: var(--font-body--weight);
    font-size: var(--font-paragraph--size);
    line-height: var(--font-paragraph--line-height);
    text-transform: var(--font-body--case);
  }

  .social-video-card__description > * {
    margin: 0;
  }

  /* Mobile aspect-ratio override. */
  @media screen and (max-width: 749px) {
    .social-video-card__media deferred-media[style*='--size-style-aspect-ratio-mobile'] {
      --size-style-aspect-ratio: var(--size-style-aspect-ratio-mobile) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Social media video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.content"
    },
    {
      "type": "text",
      "id": "account",
      "label": "Account",
      "default": "@Account"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Video title"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>0 views</p>"
    },
    {
      "type": "header",
      "content": "t:names.video"
    },
    {
      "type": "select",
      "id": "source",
      "label": "t:settings.video_source",
      "options": [
        {
          "value": "uploaded",
          "label": "t:options.video_uploaded"
        },
        {
          "value": "url",
          "label": "t:options.video_external_url"
        }
      ],
      "default": "uploaded"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:settings.video",
      "visible_if": "{{ block.settings.source == 'uploaded' }}"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "t:settings.video_external_url",
      "info": "t:info.video_external",
      "accept": ["youtube", "vimeo"],
      "visible_if": "{{ block.settings.source == 'url' }}"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "t:settings.video_autoplay",
      "info": "t:info.video_autoplay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "t:settings.video_loop",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:settings.cover_image",
      "visible_if": "{{ block.settings.source == 'url' and block.settings.video_autoplay == false }}"
    },
    {
      "type": "text",
      "id": "alt",
      "label": "t:settings.video_alt_text",
      "info": "t:info.video_alt_text",
      "visible_if": "{{ block.settings.source == 'url' }}"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.width_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:settings.aspect_ratio",
      "info": "Overrides the source's native aspect ratio.",
      "options": [
        { "value": "auto", "label": "t:options.auto" },
        { "value": "9/16", "label": "Portrait 9:16" },
        { "value": "3/4", "label": "Portrait 3:4" },
        { "value": "4/5", "label": "Portrait 4:5" },
        { "value": "1/1", "label": "Square" },
        { "value": "6.9/5", "label": "Landscape 6.9:5" },
        { "value": "16/9", "label": "Landscape 16:9" }
      ],
      "default": "9/16"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Mobile aspect ratio",
      "info": "Overrides the aspect ratio on screens under 750px.",
      "options": [
        { "value": "", "label": "Same as desktop" },
        { "value": "auto", "label": "Auto" },
        { "value": "3.6/3", "label": "Portrait 3.6:3" },
        { "value": "3/4", "label": "Portrait 3:4" },
        { "value": "4/5", "label": "Portrait 4:5" },
        { "value": "9/16", "label": "Portrait 9:16" },
        { "value": "1/1", "label": "Square" },
        { "value": "6.9/5", "label": "Landscape 6.9:5" },
        { "value": "16/9", "label": "Landscape 16:9" }
      ],
      "default": ""
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        },
        {
          "value": "dashed",
          "label": "t:options.dashed"
        }
      ],
      "default": "dashed"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 2,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:settings.color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Social media video",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
