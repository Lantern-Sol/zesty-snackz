{%- assign glow_color = 'transparent' -%}
{%- assign glow_size = 0 -%}
{%- if block.settings.enable_glow -%}
  {%- assign glow_color = block.settings.glow_color -%}
  {%- assign glow_size = block.settings.glow_size -%}
{%- endif -%}

<scroll-highlight-text
  class="scroll-highlight-text{% if request.design_mode %} scroll-highlight-text--design-mode{% endif %}"
  style="
    --sht-dim-color: {{ block.settings.dim_color }};
    --sht-highlight-color: {{ block.settings.highlight_color }};
    --sht-glow-color: {{ glow_color }};
    --sht-glow-size: {{ glow_size }}px;
    --sht-font-family: {{ block.settings.font }};
    --sht-font-size: {{ block.settings.font_size }};
    --sht-font-size-mobile: {{ block.settings.mobile_font_size }};
    --sht-line-height: {{ block.settings.line_height }};
    text-align: {{ block.settings.alignment }};
    text-transform: {{ block.settings.case }};
    {% render 'spacing-padding', settings: block.settings %}
  "
  data-split="{{ block.settings.split }}"
  data-start="{{ block.settings.start_position }}"
  data-end="{{ block.settings.end_position }}"
  {{ block.shopify_attributes }}
>
  <div class="scroll-highlight-text__content rte{% if block.settings.mobile_text != blank %} scroll-highlight-text__content--desktop{% endif %}">
    {{ block.settings.text }}
  </div>
  {% if block.settings.mobile_text != blank %}
    <div class="scroll-highlight-text__content scroll-highlight-text__content--mobile rte">
      {{ block.settings.mobile_text }}
    </div>
  {% endif %}
  <div class="scroll-highlight-text__stickers" hidden>
    {% content_for 'blocks' %}
  </div>
</scroll-highlight-text>

{% stylesheet %}
  .scroll-highlight-text {
    display: block;
    width: 100%;
    padding-block: var(--padding-block-start, 0rem) var(--padding-block-end, 0rem);
    padding-inline: var(--padding-inline-start, 0rem) var(--padding-inline-end, 0rem);
  }

  @media screen and (max-width: 749px) {
    .scroll-highlight-text {
      padding-block: var(--padding-block-start-mobile, 0rem) var(--padding-block-end-mobile, 0rem);
      padding-inline: var(--padding-inline-start-mobile, 0rem) var(--padding-inline-end-mobile, 0rem);
    }
  }

  .scroll-highlight-text__content {
    font-family: var(--sht-font-family);
    font-size: var(--sht-font-size-mobile);
    line-height: var(--sht-line-height);
    /* Fully lit by default: no-JS, no-GSAP, and reduced-motion all get readable text */
    color: var(--sht-highlight-color);
  }

  @media screen and (min-width: 750px) {
    .scroll-highlight-text__content {
      font-size: var(--sht-font-size);
    }
  }

  /* The --desktop modifier is only applied when a mobile copy exists, so the
     single-copy case always stays visible on both breakpoints */
  @media screen and (max-width: 749px) {
    .scroll-highlight-text__content--desktop {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    .scroll-highlight-text__content--mobile {
      display: none;
    }
  }

  .scroll-highlight-text__content p {
    margin: 0;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
  }

  /* Words never break across lines; characters light up inside them */
  .sht-word {
    display: inline-block;
    white-space: pre;
  }

  .sht-unit {
    color: var(--sht-dim-color);
    transition: color 0.35s ease, text-shadow 0.35s ease, filter 0.35s ease;
  }

  .sht-unit.is-lit {
    color: var(--sht-highlight-color);
    text-shadow: 0 0 var(--sht-glow-size) var(--sht-glow-color);
  }

  /* Stickers dim to a washed-out state and return to full color when lit */
  .text-sticker.sht-unit {
    filter: grayscale(0.7) brightness(0.7) opacity(0.65);
  }

  .text-sticker.sht-unit.is-lit {
    filter: drop-shadow(0 0 calc(var(--sht-glow-size) / 2) var(--sht-glow-color));
  }

  /* In the theme editor, stickers whose key isn't placed in the text yet
     show in a dashed strip below so merchants can see and select them */
  .scroll-highlight-text--design-mode .scroll-highlight-text__stickers[hidden]:has([data-sticker-key]) {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    padding: 0.5rem;
    border: 1px dashed rgb(from var(--sht-dim-color) r g b / 60%);
    border-radius: 4px;
    opacity: 0.7;
  }
{% endstylesheet %}

{% javascript %}
  if (!customElements.get('scroll-highlight-text')) {
    class ScrollHighlightText extends HTMLElement {
      connectedCallback() {
        this.#refresh();
        // A separate mobile text copy can swap in at the breakpoint, so
        // re-resolve which copy drives the animation when it flips
        this.#mobileQuery.addEventListener('change', this.#onBreakpointChange);
        if (window.Shopify && window.Shopify.designMode) {
          document.addEventListener('shopify:section:load', this.#onSectionLoad);
        }
      }

      disconnectedCallback() {
        if (this.#onLoad) window.removeEventListener('load', this.#onLoad);
        document.removeEventListener('shopify:section:load', this.#onSectionLoad);
        this.#squeezeQuery.removeEventListener('change', this.#onLayoutChange);
        this.#mobileQuery.removeEventListener('change', this.#onBreakpointChange);
        if (this.#trigger) this.#trigger.kill();
      }

      #mobileQuery = window.matchMedia('(max-width: 749px)');
      #onBreakpointChange = () => this.#refresh();

      #onLoad = null;
      #trigger = null;
      #units = [];
      #litCount = -1;
      #stickers = new Map();
      #usedStickers = new Set();
      #tokenSplitter = /(\[[a-zA-Z0-9_-]+\])/;
      // Editor edits morph the section DOM in place without reconnecting
      // this element, so re-run on section load
      #onSectionLoad = (event) => {
        if (event.target instanceof HTMLElement && event.target.contains(this)) this.#refresh();
      };

      #refresh() {
        this.#prepare();

        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          this.#light(1);
          return;
        }

        if (window.gsap && window.ScrollTrigger) {
          this.#init();
        } else if (document.readyState === 'complete') {
          // GSAP disabled in theme settings — show the text fully lit
          this.#light(1);
        } else if (!this.#onLoad) {
          this.#onLoad = () => (window.gsap && window.ScrollTrigger ? this.#init() : this.#light(1));
          window.addEventListener('load', this.#onLoad, { once: true });
        }
      }
      // On desktop the theme scrolls .page-wrapper, not the window (see scroll-container.js)
      #squeezeQuery = window.matchMedia('(min-width: 990px)');
      #onLayoutChange = () => this.#init();

      #scroller() {
        if (this.#squeezeQuery.matches) {
          return document.querySelector('.page-wrapper') ?? window;
        }
        return window;
      }

      #prepare() {
        const contents = Array.from(this.querySelectorAll('.scroll-highlight-text__content'));
        if (!contents.length) return;

        // Detect the split by its spans, not a flag: editor edits can morph
        // the DOM back to its server-rendered (unsplit) state in place
        const unsplit = contents.filter((el) => !el.querySelector('.sht-unit'));
        if (unsplit.length) {
          this.#stickers = new Map(
            Array.from(this.querySelectorAll('.scroll-highlight-text__stickers [data-sticker-key]')).map(
              (el) => [el.dataset.stickerKey, el]
            )
          );
          this.#usedStickers = new Set();

          // Keys match bracketed ([gummy]) or bare (gummy), longest key first
          const keys = Array.from(this.#stickers.keys())
            .filter(Boolean)
            .sort((a, b) => b.length - a.length)
            .map((key) => key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'));
          this.#tokenSplitter = keys.length
            ? new RegExp(`(\\[[a-zA-Z0-9_-]+\\]|\\b(?:${keys.join('|')})\\b)`, 'i')
            : /(\[[a-zA-Z0-9_-]+\])/;

          unsplit.forEach((el) => this.#splitWords(el, this.dataset.split === 'characters'));
        }

        // With a separate mobile copy, only the breakpoint-visible one drives
        // the animation; the hidden copy's units would skew the progress count
        const visible = contents.find((el) => getComputedStyle(el).display !== 'none') ?? contents[0];
        this.#units = Array.from(visible.querySelectorAll('.sht-unit'));
        this.#litCount = -1;
      }

      #init() {
        if (!this.#units.length) return;

        gsap.registerPlugin(ScrollTrigger);

        if (this.#trigger) this.#trigger.kill();
        this.#litCount = -1;

        const start = parseInt(this.dataset.start, 10) || 85;
        const end = parseInt(this.dataset.end, 10) || 45;

        this.#trigger = ScrollTrigger.create({
          trigger: this,
          scroller: this.#scroller(),
          start: `top ${start}%`,
          end: `bottom ${end}%`,
          onUpdate: (self) => this.#light(self.progress),
          onRefresh: (self) => this.#light(self.progress),
        });

        this.#squeezeQuery.removeEventListener('change', this.#onLayoutChange);
        this.#squeezeQuery.addEventListener('change', this.#onLayoutChange);
      }

      // Moves the sticker element into the text; clones it if the key is reused
      #takeSticker(key) {
        const source = this.#stickers.get(key);
        if (!source) return null;
        const sticker = this.#usedStickers.has(key) ? source.cloneNode(true) : source;
        this.#usedStickers.add(key);
        sticker.classList.add('sht-unit');
        return sticker;
      }

      #light(progress) {
        // Re-split if a DOM morph replaced the spans since the last update
        if (this.#units.length && !this.#units[0].isConnected) this.#prepare();
        const count = Math.round(progress * this.#units.length);
        if (count === this.#litCount) return;
        this.#units.forEach((unit, i) => unit.classList.toggle('is-lit', i < count));
        this.#litCount = count;
      }

      // Wraps each word in a span (and each character in a nested span when
      // perCharacter), preserving inline elements like <strong> and <a>
      #splitWords(node, perCharacter) {
        Array.from(node.childNodes).forEach((child) => {
          if (child.nodeType === Node.ELEMENT_NODE) {
            this.#splitWords(child, perCharacter);
            return;
          }
          if (child.nodeType !== Node.TEXT_NODE || !child.textContent.trim()) return;

          const fragment = document.createDocumentFragment();
          // [key] placeholders are replaced by their sticker; a bare key keeps
          // the word and renders its sticker just before it
          child.textContent.split(this.#tokenSplitter).forEach((segment) => {
            if (!segment) return;

            const bracket = segment.match(/^\[([a-zA-Z0-9_-]+)\]$/);
            if (bracket) {
              const sticker = this.#takeSticker(bracket[1].toLowerCase());
              if (sticker) {
                fragment.appendChild(sticker);
                return;
              }
            } else {
              const sticker = this.#takeSticker(segment.toLowerCase());
              if (sticker) fragment.appendChild(sticker);
            }

            segment.split(/(\s+)/).forEach((part) => {
              if (!part) return;
              if (!part.trim()) {
                fragment.appendChild(document.createTextNode(part));
                return;
              }
              const word = document.createElement('span');
              word.className = 'sht-word';
              if (perCharacter) {
                for (const char of part) {
                  const unit = document.createElement('span');
                  unit.className = 'sht-unit';
                  unit.textContent = char;
                  word.appendChild(unit);
                }
              } else {
                word.classList.add('sht-unit');
                word.textContent = part;
              }
              fragment.appendChild(word);
            });
          });
          child.replaceWith(fragment);
        });
      }
    }

    customElements.define('scroll-highlight-text', ScrollHighlightText);
  }
{% endjavascript %}

{% schema %}
{
  "name": "Scroll highlight text",
  "tag": null,
  "blocks": [
    {
      "type": "_text-sticker"
    }
  ],
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "t:settings.text",
      "default": "<p>Sour candy, sliced paper-thin. It crunches. It melts. It never takes a molar hostage.</p>",
      "info": "Add a Sticker block and give it a key. Type the key as a plain word (e.g. gummy) to show the sticker before that word, or in square brackets (e.g. [gummy]) to show the sticker on its own."
    },
    {
      "type": "richtext",
      "id": "mobile_text",
      "label": "Mobile text",
      "info": "Optional. Replaces the text on mobile. Sticker keys work here too."
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "select",
      "id": "split",
      "label": "Highlight by",
      "options": [
        {
          "value": "characters",
          "label": "Character"
        },
        {
          "value": "words",
          "label": "Word"
        }
      ],
      "default": "characters"
    },
    {
      "type": "range",
      "id": "start_position",
      "label": "Start when top of text reaches",
      "info": "Percentage of the viewport height, measured from the top.",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85
    },
    {
      "type": "range",
      "id": "end_position",
      "label": "Finish when bottom of text reaches",
      "min": 10,
      "max": 80,
      "step": 5,
