{%- doc -%}
  Countdown Timer block
  ---------------------
  A dark rounded card with a headline, four unit boxes (days / hours / minutes /
  seconds) counting down to a fixed instant, and a supporting line of copy.

  The deadline is built in Liquid from the merchant's date + time settings and
  stamped with the store's UTC offset, so every visitor counts down to the same
  moment regardless of their own timezone. countdown-timer.js ticks the cells
  each second and stops at zero.

  @example
  {% content_for 'block', type: 'countdown-timer', id: 'countdown-timer' %}
{%- enddoc -%}

<script
  src="{{ 'countdown-timer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% liquid
  assign end_date = block.settings.end_date | default: '2026-07-25'
  assign end_time = block.settings.end_time | default: '12:00'

  assign raw_offset = 'now' | date: '%z'
  assign offset_h = raw_offset | slice: 0, 3
  assign offset_m = raw_offset | slice: 3, 2
  if offset_h == blank
    assign offset_h = '+00'
    assign offset_m = '00'
  endif

  assign deadline_iso = end_date | append: 'T' | append: end_time | append: ':00' | append: offset_h | append: ':' | append: offset_m
%}

<div
  class="countdown spacing-style"
  style="
    {%- render 'spacing-style', settings: block.settings %}
    --countdown-bg: {{ block.settings.background_color }};
    --countdown-title: {{ block.settings.title_color }};
    --countdown-text: {{ block.settings.text_color }};
    --countdown-box-bg: {{ block.settings.box_background_color }};
    --countdown-box-border: {{ block.settings.box_border_color }};
    --countdown-number: {{ block.settings.number_color }};
    --countdown-label: {{ block.settings.label_color }};
    --countdown-shadow: {{ block.settings.shadow_color }};
  "
  {{ block.shopify_attributes }}
>
  <div class="countdown__card">
    {%- if block.settings.title != blank -%}
      <p class="countdown__title">{{ block.settings.title }}</p>
    {%- endif -%}

    <countdown-timer
      class="countdown__grid"
      data-deadline="{{ deadline_iso }}"
      role="timer"
      aria-label="{{ block.settings.title | strip_html | default: 'Countdown' | escape }}"
    >
      {%- assign units = 'days,hours,minutes,seconds' | split: ',' -%}
      {%- for unit in units -%}
        {%- liquid
          assign label_key = unit | append: '_label'
          assign label = block.settings[label_key]
        -%}
        <div class="countdown__unit">
          <span class="countdown__number" data-unit="{{ unit }}">00</span>
          {%- if label != blank -%}
            <span class="countdown__label">{{ label }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </countdown-timer>

    {%- if block.settings.subtitle != blank -%}
      <p class="countdown__subtitle">{{ block.settings.subtitle }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .countdown {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .countdown__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    max-width: 46.32rem;
    padding: 3rem;
    border-radius: 2rem;
    background: var(--countdown-bg);
    box-shadow: 0 0.3125rem 0 0 var(--countdown-shadow);
  }

  .countdown__title {
    margin: 0;
    font-family: var(--font-heading--family);
    font-weight: 400;
    font-size: 2rem;
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-align: center;
    text-transform: uppercase;
    color: var(--countdown-title);
  }

  .countdown__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
    width: 100%;
  }

  .countdown__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    width: calc(25% - 1.25rem * 3 / 4);
    padding: 1.19rem 1.19rem 0.94rem;
    border: 0.1875rem solid var(--countdown-box-border);
    border-radius: 1.25rem;
    background: var(--countdown-box-bg);
    box-shadow: 0 0.3125rem 0 0 var(--countdown-shadow);
  }

  .countdown__number {
    font-family: var(--font-heading--family);
    font-weight: 400;
    font-size: 5rem;
    line-height: 1;
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
    color: var(--countdown-number);
    margin-bottom: -1rem;
  }

  .countdown__label {
    font-family: var(--font-heading--family);
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.5;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--countdown-label);
  }

  .countdown__subtitle {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: clamp(0.875rem, 1.6vw, 1rem);
    line-height: 1.3;
    letter-spacing: 0.02em;
    text-align: center;
    color: var(--countdown-text);
  }

  @media screen and (max-width: 749px) {
    .countdown__grid {
      gap: 0.65rem;
    }
    .countdown__unit {
      width: calc(25% - 0.65rem * 3 / 4);
      padding: 0.61rem 1rem 0.46rem;
      border-radius: 11px;
    }
    .countdown__card {
      padding: 1.59rem 1.59rem 1.62rem;
      gap: 0.65rem;
    }
    .countdown__number {
      font-size: 2.58rem;
      margin-bottom: -0.5rem;
    }
    .countdown__label {
      font-size: 0.647rem;
    }
    .countdown__title {
      font-size: 1.125rem;
    }
    .countdown__subtitle {
      font-size: 0.625rem;
    }
  }
{% endstylesheet %}

