<div class="falling-group" {{ block.shopify_attributes }}>
  {% content_for 'blocks' %}
</div>

{% stylesheet %}
  .falling-group {
    /* Distance from the viewport edge to the page-width central column */
    --falling-edge-offset: calc(var(--page-margin) + max((100vw - var(--page-width)) / 2, 0px));

    position: absolute;
    inset: 0;
    z-index: var(--layer-flat);

    /* The group is a pure positioning layer; the images inside re-enable
       pointer events in the theme editor for on-canvas selection */
    pointer-events: none;
  }

  /* Images near the edges intentionally overhang the group into the page
     margins, so clip at the section (which spans the full page width) —
     otherwise they widen the page's horizontal scroll area. Only the x axis:
     the fall animation enters from above the section and must stay visible.
     `clip` not `hidden`, so no scroll container is created. */
  .section:has(.falling-group) {
    overflow-x: clip;
  }

  /* When the section constrains its content to page width, stretch the group
     to the full section width so the images inside position against it */
  @media screen and (min-width: 750px) {
    .section-content-wrapper.page-width > .falling-group {
      left: calc(-1 * var(--falling-edge-offset));
      right: calc(-1 * var(--falling-edge-offset));
    }
  }

  @media screen and (max-width: 749px) {
    .section-content-wrapper.page-width-mobile > .falling-group {
      left: calc(-1 * var(--falling-edge-offset));
      right: calc(-1 * var(--falling-edge-offset));
    }
  }

  /* Sections like the hero apply their spacing on a container above the content
     wrapper, so the wrapper starts below the section's top padding — and, for the
     first section under a transparent header, below the header-height offset too.
     The spacing-style variables inherit, so pull the group back over them to span
     the true section bounds. Skipped when the wrapper carries spacing-style itself
     (e.g. the Custom Section), where inset: 0 already covers the padding area. */
  .section-content-wrapper:not(.spacing-style) > .falling-group {
    top: calc(-1 * var(--padding-block-start, 0px) - var(--section-top-offset, 0px));
    bottom: calc(-1 * var(--padding-block-end, 0px));
  }

  @media screen and (max-width: 749px) {
    .section-content-wrapper:not(.spacing-style) > .falling-group {
      top: calc(-1 * var(--padding-block-start-mobile, var(--padding-block-start, 0px)) - var(--section-top-offset, 0px));
      bottom: calc(-1 * var(--padding-block-end-mobile, var(--padding-block-end, 0px)));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Falling group",
  "tag": null,
  "blocks": [
    {
      "type": "_falling-image"
    }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Overlay layer that holds falling images. It spans the full section, and the images inside position relative to it."
    }
  ],
  "presets": [
    {
      "name": "Falling group",
      "category": "t:categories.basic",
      "blocks": {
        "falling-image-1": {
          "type": "_falling-image"
        }
      },
      "block_order": ["falling-image-1"]
    }
  ]
}
{% endschema %}
