{% comment %}
  Gravity Fall Section

  A physics playground: bubble stickers, images, text chips and buttons drop
  from the top of the section, bounce off each other and settle into a pile.
  Items are real DOM elements (buttons stay clickable, text stays selectable
  and crawlable) driven by the lightweight engine in assets/gravity-section.js.

  - Items drop when the section scrolls into view, staggered
  - Optional drag & throw interaction (pointer)
  - Respects prefers-reduced-motion: the pile renders pre-settled, no animation
  - In the theme editor, selecting a block pops that item so it's easy to find

  Section settings:
  - height / height_mobile: section height in px
  - mobile_scale: item size multiplier on mobile (%)
  - gravity_strength: gravity multiplier
  - bounciness: restitution (0 = thud, 0.9 = super bouncy)
  - drop_stagger: delay between item drops (ms)
  - enable_drag: allow visitors to grab and throw items
  - background_gradient / background_color

  Blocks: sticker (bubble with image), image, text (circle or pill chip), button.
  Each block has an optional "Horizontal position" (0-100%); left empty, items
  spread evenly with a deterministic jitter.

  Mobile (per block): hide entirely (display:none + excluded from physics, lazy
  images never load), pin independently of desktop with its own x/y/rotation
  (pinned = desktop only, pinned_mobile = mobile only), and sizes can be set
  per item: stickers/images an explicit px size, text chips a font size, and
  buttons font size + padding (width stays fit-content). 0 = fall back to the
  global mobile item scale. The engine re-collects on breakpoint change.

  Performance: when every mobile-visible block is pinned, the section gets
  .gravity-fall--static-mobile — CSS places the pinned items and the physics
  engine (observers, rAF, collisions) never boots on mobile. Adding any
  falling mobile-visible item automatically re-enables the engine.
{% endcomment %}

<script
  src="{{ 'gravity-section.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif

  assign item_scale_mobile = section.settings.mobile_scale | divided_by: 100.0

  # When every mobile-visible block is pinned there is nothing to simulate:
  # the static class lets CSS place the pinned items and the engine skips
  # booting on mobile entirely (see gravity-section.js).
  assign all_pinned_mobile = true
  for block in section.blocks
    unless block.settings.hide_mobile or block.settings.pinned_mobile
      assign all_pinned_mobile = false
      break
    endunless
  endfor
%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<gravity-section
  class="gravity-fall section section--full-width spacing-style{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}{% if all_pinned_mobile %} gravity-fall--static-mobile{% endif %}"
  style="
    {%- render 'spacing-style', settings: section.settings %};
    --gravity-height: {{ section.settings.height }}px;
    --gravity-height-mobile: {{ section.settings.height_mobile }}px;
    --gravity-item-scale-mobile: {{ item_scale_mobile }};
    {% if section.settings.background_gradient != blank %}background-image: {{ section.settings.background_gradient }};{% endif %}
  "
  data-gravity="{{ section.settings.gravity_strength }}"
  data-restitution="{{ section.settings.bounciness }}"
  data-stagger="{{ section.settings.drop_stagger }}"
  data-floor-offset="{{ section.settings.bottom_overflow }}"
  {% if section.settings.enable_drag %}
    data-drag
  {% endif %}
  {% unless section.settings.impact_squash %}
    data-no-squash
  {% endunless %}
>
  {%- if section.settings.background_image != blank or section.settings.background_image_mobile != blank -%}
    <div
      class="gravity-fall__bg{% if section.settings.background_image_mobile != blank %} gravity-fall__bg--has-mobile{% endif %}"
      aria-hidden="true"
      style="
        --bg-size: {{ section.settings.background_image_size }};
        --bg-position: {{ section.settings.background_image_position }};
        --bg-opacity: {{ section.settings.background_image_opacity | divided_by: 100.0 }};
      "
    >
      {%- if section.settings.background_image != blank -%}
        {{
          section.settings.background_image
          | image_url: width: 3840
          | image_tag: loading: 'lazy', class: 'gravity-fall__bg-media gravity-fall__bg-media--desktop', sizes: '100vw', widths: '750, 1100, 1500, 1780, 2000, 3000, 3840'
        }}
      {%- endif -%}
      {%- if section.settings.background_image_mobile != blank -%}
        {{
          section.settings.background_image_mobile
          | image_url: width: 1500
          | image_tag: loading: 'lazy', class: 'gravity-fall__bg-media gravity-fall__bg-media--mobile', sizes: '100vw', widths: '375, 550, 750, 1100, 1500'
        }}
      {%- endif -%}
    </div>
  {%- endif -%}
  {%- for block in section.blocks -%}
    {%- liquid
      # inline vars for the static CSS placement of mobile-pinned items
      assign pin_vars = ''
      if block.settings.pinned_mobile
        assign pin_x = block.settings.position_mobile | default: block.settings.position | default: 50
        assign pin_y = block.settings.position_y_mobile | default: block.settings.position_y | default: 50
        assign pin_rot = block.settings.rotation_mobile | default: 0
        assign pin_vars = ' --pin-x-mobile: ' | append: pin_x | append: '%; --pin-y-mobile: ' | append: pin_y | append: '%; --pin-rot-mobile: ' | append: pin_rot | append: 'deg;'
      endif
    -%}
    {%- case block.type -%}
      {%- when 'sticker' -%}
        <div
          class="gravity-item gravity-item--circle{% if block.settings.hide_mobile %} gravity-item--hide-mobile{% endif %}{% if block.settings.hide_desktop %} gravity-item--hide-desktop{% endif %}{% if block.settings.size_mobile > 0 %} gravity-item--mobile-size{% endif %}"
          data-gravity-item
          data-shape="circle"
          {% if block.settings.position != blank %}
            data-x="{{ block.settings.position }}"
          {% endif %}
          {% if block.settings.pinned %}
            data-pinned
            data-y="{{ block.settings.position_y | default: 50 }}"
            data-rotation="{{ block.settings.rotation | default: 0 }}"
          {% endif %}
          {% if block.settings.pinned_mobile %}
            data-pinned-mobile
            data-x-mobile="{{ block.settings.position_mobile | default: block.settings.position | default: 50 }}"
            data-y-mobile="{{ block.settings.position_y_mobile | default: block.settings.position_y | default: 50 }}"
            data-rotation-mobile="{{ block.settings.rotation_mobile | default: 0 }}"
          {% endif %}
          style="--item-size: {{ block.settings.size }}px;{% if block.settings.size_mobile > 0 %} --item-size-mobile: {{ block.settings.size_mobile }}px;{% endif %}{{ pin_vars }}"
          {{ block.shopify_attributes }}
        >
          <div class="gravity-bubble{% if block.settings.style == 'bare' %} gravity-bubble--bare{% endif %}">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 660
                | image_tag: loading: 'lazy', class: 'gravity-bubble__media', sizes: '220px'
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'gravity-bubble__media gravity-bubble__media--placeholder' }}
            {%- endif -%}
          </div>
        </div>

      {%- when 'image' -%}
        {%- liquid
          assign image_ratio = 1
          if block.settings.image != blank
            assign image_ratio = block.settings.image.aspect_ratio
          endif
        -%}
        <div
          class="gravity-item gravity-item--image{% if block.settings.round %} gravity-item--circle{% endif %}{% if block.settings.hide_mobile %} gravity-item--hide-mobile{% endif %}{% if block.settings.hide_desktop %} gravity-item--hide-desktop{% endif %}{% if block.settings.size_mobile > 0 %} gravity-item--mobile-size{% endif %}"
          data-gravity-item
          data-shape="{% if block.settings.round %}circle{% else %}pill{% endif %}"
          {% if block.settings.position != blank %}
            data-x="{{ block.settings.position }}"
          {% endif %}
          {% if block.settings.pinned %}
            data-pinned
            data-y="{{ block.settings.position_y | default: 50 }}"
            data-rotation="{{ block.settings.rotation | default: 0 }}"
          {% endif %}
          {% if block.settings.pinned_mobile %}
            data-pinned-mobile
            data-x-mobile="{{ block.settings.position_mobile | default: block.settings.position | default: 50 }}"
            data-y-mobile="{{ block.settings.position_y_mobile | default: block.settings.position_y | default: 50 }}"
            data-rotation-mobile="{{ block.settings.rotation_mobile | default: 0 }}"
          {% endif %}
          style="--item-size: {{ block.settings.size }}px; --item-ratio: {{ image_ratio }};{% if block.settings.size_mobile > 0 %} --item-size-mobile: {{ block.settings.size_mobile }}px;{% endif %}{{ pin_vars }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag: loading: 'lazy', class: 'gravity-image__media', sizes: '300px'
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'gravity-image__media gravity-image__media--placeholder' }}
          {%- endif -%}
        </div>

      {%- when 'text' -%}
        <div
          class="gravity-item gravity-item--text{% if block.settings.hide_mobile %} gravity-item--hide-mobile{% endif %}{% if block.settings.hide_desktop %} gravity-item--hide-desktop{% endif %}{% if block.settings.font_size_mobile > 0 %} gravity-item--mobile-size{% endif %}"
          data-gravity-item
          data-keep-upright
          data-shape="{% if block.settings.shape == 'circle' %}circle{% else %}pill{% endif %}"
          {% if block.settings.position != blank %}
            data-x="{{ block.settings.position }}"
          {% endif %}
          {% if block.settings.pinned %}
            data-pinned
            data-y="{{ block.settings.position_y | default: 50 }}"
            data-rotation="{{ block.settings.rotation | default: 0 }}"
          {% endif %}
          {% if block.settings.pinned_mobile %}
            data-pinned-mobile
            data-x-mobile="{{ block.settings.position_mobile | default: block.settings.position | default: 50 }}"
            data-y-mobile="{{ block.settings.position_y_mobile | default: block.settings.position_y | default: 50 }}"
            data-rotation-mobile="{{ block.settings.rotation_mobile | default: 0 }}"
          {% endif %}
          style="
            {% if block.settings.text_color != blank %}--item-text-color: {{ block.settings.text_color }};{% endif %}
            {% if block.settings.chip_color != blank %}--item-chip-color: {{ block.settings.chip_color }};{% endif %}
            {% if block.settings.font_size_mobile > 0 %}--item-font-size-mobile: {{ block.settings.font_size_mobile }}px;{% endif %}
            {{ pin_vars }}
          "
          {{ block.shopify_attributes }}
        >
          <div class="gravity-chip gravity-chip--{{ block.settings.shape }}">
            <div class="gravity-chip__text rte">{{ block.settings.text }}</div>
          </div>
        </div>

      {%- when 'button' -%}
        <div
          class="gravity-item gravity-item--button{% if block.settings.width_type == 'full' %} gravity-item--full-width{% endif %}{% if block.settings.hide_mobile %} gravity-item--hide-mobile{% endif %}{% if block.settings.hide_desktop %} gravity-item--hide-desktop{% endif %}{% if block.settings.font_size_mobile > 0 %} gravity-item--mobile-font{% endif %}{% if block.settings.padding_vertical_mobile > 0 %} gravity-item--mobile-pad-v{% endif %}{% if block.settings.padding_horizontal_mobile > 0 %} gravity-item--mobile-pad-h{% endif %}"
          data-gravity-item
          data-shape="pill"
          {% if block.settings.position != blank %}
            data-x="{{ block.settings.position }}"
          {% endif %}
          {% if block.settings.pinned %}
            data-pinned
            data-y="{{ block.settings.position_y | default: 50 }}"
            data-rotation="{{ block.settings.rotation | default: 0 }}"
          {% endif %}
          {% if block.settings.pinned_mobile %}
            data-pinned-mobile
            data-x-mobile="{{ block.settings.position_mobile | default: block.settings.position | default: 50 }}"
            data-y-mobile="{{ block.settings.position_y_mobile | default: block.settings.position_y | default: 50 }}"
            data-rotation-mobile="{{ block.settings.rotation_mobile | default: 0 }}"
          {% endif %}
          style="
            {% if block.settings.font_size_mobile > 0 %}--button-font-size-mobile: {{ block.settings.font_size_mobile }}px;{% endif %}
            {% if block.settings.padding_vertical_mobile > 0 %}--button-padding-block-mobile: {{ block.settings.padding_vertical_mobile }}px;{% endif %}
            {% if block.settings.padding_horizontal_mobile > 0 %}--button-padding-inline-mobile: {{ block.settings.padding_horizontal_mobile }}px;{% endif %}
            {{ pin_vars }}
          "
          {{ block.shopify_attributes }}
        >
          {% render 'button-custom-styles', block_settings: block.settings, block_id: block.id %}
          <a
            class="{{ block.settings.style_class }} {{ block.settings.style_class }}--{{ block.id }}"
            {% if block.settings.link != blank %}
              href="{{ block.settings.link }}"
            {% else %}
              role="link"
              aria-disabled="true"
            {% endif %}
            {% if block.settings.open_in_new_tab %}
              target="_blank"
              rel="noopener"
            {% endif %}
          >
            {{ block.settings.label | escape }}
          </a>
        </div>
    {%- endcase -%}
  {%- endfor -%}
</gravity-section>

{% stylesheet %}
  gravity-section {
    display: block;
    position: relative;
    width: 100%;
    height: var(--gravity-height, 600px);
    overflow: clip;
    background-size: cover;
    background-position: center;
    --item-scale: 1;
  }

  /* hidden items are also excluded from the physics simulation */
  @media screen and (min-width: 750px) {
    .gravity-item--hide-desktop {
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
    gravity-section {
      height: var(--gravity-height-mobile, 480px);
      --item-scale: var(--gravity-item-scale-mobile, 0.7);
    }

    /* hidden items are also excluded from the physics simulation */
    .gravity-item--hide-mobile {
      display: none;
    }

    .gravity-item--button.gravity-item--mobile-font > a {
      font-size: var(--button-font-size-mobile);
    }

    .gravity-item--button.gravity-item--mobile-pad-v > a {
      padding-block: var(--button-padding-block-mobile);
    }

    .gravity-item--button.gravity-item--mobile-pad-h > a {
      padding-inline: var(--button-padding-inline-mobile);
    }

    /* explicit mobile sizes override the global mobile item scale */
    .gravity-item--mobile-size.gravity-item--circle {
      width: var(--item-size-mobile);
      height: var(--item-size-mobile);
    }

    .gravity-item--mobile-size.gravity-item--image:not(.gravity-item--circle) {
      width: var(--item-size-mobile);
    }

    /* headings inside rich text get their font-size from base.css element
       rules, so inheritance from the chip isn't enough — target them too */
    .gravity-item--mobile-size .gravity-chip,
    .gravity-item--mobile-size .gravity-chip :is(h1, h2, h3, h4, h5, h6, p) {
      font-size: var(--item-font-size-mobile);
    }

    /* All-pinned mobile layouts skip the physics engine entirely (see
       gravity-section.js); these rules place the pinned items instead.
       Scoped to the static class so the engine's transform positioning is
       never double-offset when it does run. */
    .gravity-fall--static-mobile .gravity-item[data-pinned-mobile] {
      top: var(--pin-y-mobile, 50%);
      left: var(--pin-x-mobile, 50%);
      translate: -50% -50%;
      rotate: var(--pin-rot-mobile, 0deg);
      transform: none;
    }

    /* Abs-positioned fit-content items shrink to the space right of their
       `left` offset, wrapping chip/button text. max-content sizes them to
       their content like the engine's transform placement did; the cap keeps
       long unbroken text wrapping at the section width. Circles, images and
       full-width buttons keep their explicit widths. */
    .gravity-fall--static-mobile .gravity-item--text[data-pinned-mobile],
    .gravity-fall--static-mobile .gravity-item--button[data-pinned-mobile]:not(.gravity-item--full-width) {
      width: max-content;
      max-width: 100%;
    }
  }

  .gravity-item {
    position: absolute;
    top: 0;
    left: 0;
    width: fit-content;
    will-change: transform;
    /* parked above the section (clipped) until the engine positions it */
    transform: translate3d(0, -150%, 0);
  }

  .gravity-fall__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .gravity-fall__bg-media {
    width: 100%;
    height: 100%;
    object-fit: var(--bg-size, cover);
    object-position: var(--bg-position, center);
    opacity: var(--bg-opacity, 1);
  }

  /* the mobile image swaps in under the breakpoint; hidden + lazy means
     the off-breakpoint image is never downloaded */
  .gravity-fall__bg-media--mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .gravity-fall__bg--has-mobile .gravity-fall__bg-media--desktop {
      display: none;
    }

    .gravity-fall__bg-media--mobile {
      display: block;
    }
  }

  gravity-section[data-drag] .gravity-item {
    touch-action: none;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  gravity-section[data-drag] .gravity-item:active {
    cursor: grabbing;
  }

  /* Touch: leave vertical pans to the browser so visitors can scroll past
     the section — horizontal drags still grab and throw items. Static-mobile
     layouts have no engine, so nothing is draggable at all. */
  @media screen and (max-width: 749px) {
    gravity-section[data-drag] .gravity-item {
      touch-action: pan-y;
    }

    gravity-section[data-drag].gravity-fall--static-mobile .gravity-item {
      touch-action: auto;
      cursor: auto;
      user-select: auto;
      -webkit-user-select: auto;
    }
  }

  /* Pinned items: the engine owns the wrapper transform, so the entrance
     wobble and hover tilt live on the inner element where they compose
     with the pinned rotation */
  .gravity-item[data-pinned] > * {
    transition: transform 0.25s ease;
  }

  .gravity-item[data-pinned]:hover > * {
    transform: rotate(3deg);
  }

  @media (prefers-reduced-motion: no-preference) {
    gravity-section.is-started .gravity-item[data-pinned] > * {
      animation: gravity-pin-tilt 1s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
  }

  @keyframes gravity-pin-tilt {
    0% {
      transform: rotate(0deg);
    }

    25% {
      transform: rotate(-4deg);
    }

    55% {
      transform: rotate(2.5deg);
    }

    80% {
      transform: rotate(-1deg);
    }

    100% {
      transform: rotate(0deg);
    }
  }

  .gravity-item--circle {
    width: calc(var(--item-size, 120px) * var(--item-scale));
    height: calc(var(--item-size, 120px) * var(--item-scale));
  }

  .gravity-item--image:not(.gravity-item--circle) {
    width: calc(var(--item-size, 140px) * var(--item-scale));
    aspect-ratio: var(--item-ratio, 1);
  }

  .gravity-bubble {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background:
      radial-gradient(
        circle at 30% 25%,
        rgb(255 255 255 / 55%),
        rgb(255 255 255 / 12%) 45%,
        rgb(255 255 255 / 4%) 70%
      ),
      rgb(255 255 255 / 14%);
    border: 1.5px solid rgb(255 255 255 / 70%);
    box-shadow:
      inset 0 -8px 18px rgb(255 255 255 / 18%),
      0 6px 18px rgb(0 0 0 / 8%);
  }

  .gravity-bubble--bare {
    background: none;
    border: none;
    box-shadow: none;
  }

  .gravity-bubble__media {
    width: 72%;
    height: 72%;
    object-fit: contain;
    pointer-events: none;
  }

  .gravity-bubble__media--placeholder,
  .gravity-image__media--placeholder {
    opacity: 0.5;
  }

  .gravity-image__media {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .gravity-item--circle .gravity-image__media {
    border-radius: 50%;
    object-fit: cover;
  }

  .gravity-chip {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    width: fit-content;
    font-size: calc(var(--font-paragraph--size, 1rem) * var(--item-scale));
    color: var(--item-text-color, var(--color-foreground));
    background:
      radial-gradient(
        circle at 30% 25%,
        rgb(255 255 255 / 45%),
        rgb(255 255 255 / 0%) 60%
      ),
      var(--item-chip-color, rgb(255 255 255 / 20%));
    border: 1.5px solid rgb(255 255 255 / 70%);
    box-shadow: 0 6px 18px rgb(0 0 0 / 8%);
  }

  /* circle and square size themselves from the text content */
  .gravity-chip--circle {
    border-radius: 50%;
    aspect-ratio: 1;
    padding: 1.6em;
  }

  /* square is bare text: no chip styling at all */
  .gravity-chip--square {
    background: none;
    border: none;
    box-shadow: none;
    padding: 0;
  }

  .gravity-chip--pill {
    border-radius: 999px;
    padding: 0.6em 1.4em;
  }

  .gravity-chip__text > * {
    margin: 0;
  }

  .gravity-item--button .button {
    white-space: nowrap;
  }

  /* full-width buttons span the section minus 20px inline padding */
  .gravity-item--button.gravity-item--full-width {
    width: calc(100% - 40px);
  }

  .gravity-item--button.gravity-item--full-width > a {
    width: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gravity fall",
  "tag": "div",
  "class": "gravity-fall-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 30,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height",
      "min": 300,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Height (mobile)",
      "min": 200,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 480
    },
    {
      "type": "range",
      "id": "mobile_scale",
      "label": "Item size on mobile",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70
    },
    {
      "type": "range",
      "id": "bottom_overflow",
      "label": "Bottom overflow",
      "info": "Sinks the pile's floor below the section edge, so the lowest items look cut off.",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "Physics"
    },
    {
      "type": "range",
      "id": "gravity_strength",
      "label": "Gravity",
      "min": 0.2,
      "max": 3,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "range",
      "id": "bounciness",
      "label": "Bounciness",
      "min": 0,
      "max": 0.9,
      "step": 0.1,
      "default": 0.4
    },
    {
      "type": "range",
      "id": "drop_stagger",
      "label": "Delay between drops",
      "min": 0,
      "max": 500,
      "step": 20,
      "unit": "ms",
      "default": 120
    },
    {
      "type": "checkbox",
      "id": "enable_drag",
      "label": "Let visitors drag and throw items",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "impact_squash",
      "label": "Squash and stretch on impact",
      "info": "Items stretch slightly while falling and flatten when they land, like a bouncing ball.",
      "default": true
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image (mobile)",
