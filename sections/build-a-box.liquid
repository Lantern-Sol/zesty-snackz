{% render 'contrast-override', background_color: section.settings.background_color, section_id: section.id %}
<div class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"></div>

{%- liquid
  # ---------------------------------------------------------------------------
  # Tier data (blocks of type "tier", ordered by quantity in the editor).
  # max_qty drives milestone positions and the hard cap on bundle size.
  # ---------------------------------------------------------------------------
  assign max_qty = 0
  assign min_qty = 0
  for block in section.blocks
    if block.type == 'tier'
      if block.settings.quantity > max_qty
        assign max_qty = block.settings.quantity
      endif
      if min_qty == 0 or block.settings.quantity < min_qty
        assign min_qty = block.settings.quantity
      endif
    endif
  endfor
  if max_qty == 0
    assign max_qty = 12
  endif
  if min_qty == 0
    assign min_qty = 3
  endif

  # Products come directly from the Appstle Build-a-Box: its product set is the
  # selling plan group configured on the bundle (default "Single Bag Plans"),
  # so any product whose single-bag variant belongs to that group is shown.
  assign plan_group_name = section.settings.plan_group_name | default: 'Single Bag Plans'
  assign accent = section.settings.accent_color | default: '#5B8DEF'
-%}

<build-a-box-section
  class="
    section
    section--{{ section.settings.section_width }}
    {% if section.settings.background_color != blank %}color-custom-{{ section.id }}{% endif %}
    section-build-a-box
    spacing-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    --bab-accent: {{ accent }};
    --bab-accent-soft: {{ section.settings.accent_soft_color | default: '#DBE6FB' }};
    --bab-cta-bg: {{ section.settings.cta_color | default: '#FFD23F' }};
    --bab-cta-shadow: {{ section.settings.cta_shadow_color | default: '#E0A800' }};
    --bab-success: {{ section.settings.success_color | default: '#3FA34D' }};
  "
  data-section-id="{{ section.id }}"
  data-min-qty="{{ min_qty }}"
  data-max-qty="{{ max_qty }}"
  data-subscribe-default="{{ section.settings.subscribe_default_on }}"
  {% if section.settings.appstle_bundle_handle != blank %}
    data-appstle-bundle-handle="{{ section.settings.appstle_bundle_handle }}"
  {% endif %}
  data-mobile-limit="{{ section.settings.mobile_initial_products }}"
  data-testid="build-a-box"
>
  <script type="application/json" data-bab-tiers>
    [
      {%- for block in section.blocks -%}
        {%- if block.type == 'tier' -%}
          {
            "name": {{ block.settings.name | json }},
            "quantity": {{ block.settings.quantity | json }},
            "discount": {{ block.settings.discount | json }},
            "perks": {{ block.settings.perks | json }},
            "freeShipping": {{ block.settings.free_shipping | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  </script>

  <div class="bab__top">
    <div class="bab__main">
      {%- liquid
        # Boat banner: a layered, gently-rocking scene (topo → back water → boat
        # → front water) whose cargo well is filled at runtime with the shopper's
        # selected product images (see build-a-box.js #renderBoat). Each layer can
        # be overridden in the editor; otherwise the bundled Figma assets are used.
        assign topo_src = 'bab-boat-topo.png' | asset_url
        if section.settings.topo_image != blank
          assign topo_src = section.settings.topo_image | image_url: width: 1600
        endif
        assign water_back_src = 'bab-boat-water-back.png' | asset_url
        if section.settings.water_back_image != blank
          assign water_back_src = section.settings.water_back_image | image_url: width: 1600
        endif
        assign water_front_src = 'bab-boat-water-front.png' | asset_url
        if section.settings.water_front_image != blank
          assign water_front_src = section.settings.water_front_image | image_url: width: 1600
        endif
        assign boat_src = 'bab-boat.png' | asset_url
        if section.settings.boat_image != blank
          assign boat_src = section.settings.boat_image | image_url: width: 820
        endif
      -%}
      <div class="bab__banner" data-bab-boat-scene style="--bab-badge: url('{{ 'bab-badge.svg' | asset_url }}');">
        <div class="bab__scene">
          <div class="bab__scene-topo" style="background-image: url('{{ topo_src }}');"></div>

          <img
            class="bab__scene-water bab__scene-water--back"
            src="{{ water_back_src }}"
            alt=""
            role="presentation"
            width="798"
            height="151"
            loading="lazy"
          >

          <div class="bab__boat" data-bab-boat>
            <img
              class="bab__boat-img"
              src="{{ boat_src }}"
              alt=""
              role="presentation"
              width="410"
              height="216"
              loading="lazy"
            >
            <div class="bab__boat-cargo" data-bab-boat-cargo aria-hidden="true"></div>
          </div>

          <img
            class="bab__scene-water bab__scene-water--front"
            src="{{ water_front_src }}"
            alt=""
            role="presentation"
            width="798"
            height="63"
            loading="lazy"
          >
        </div>

        {%- if section.settings.banner_title != blank or section.settings.banner_perk_1 != blank -%}
          <div class="bab__scene-copy">
            {%- if section.settings.banner_title != blank -%}
              <p class="bab__scene-title">{{ section.settings.banner_title }}</p>
            {%- endif -%}
            <ul class="bab__scene-perks" role="list">
              {%- for i in (1..3) -%}
                {%- liquid
                  case i
                    when 1
                      assign perk = section.settings.banner_perk_1
                    when 2
                      assign perk = section.settings.banner_perk_2
                    when 3
                      assign perk = section.settings.banner_perk_3
                  endcase
                -%}
                {%- if perk != blank -%}
                  <li class="bab__scene-perk">
                    <span class="bab__scene-perk-num">{{ i }}</span>
                    <span class="bab__scene-perk-text">{{ perk }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

      {% comment %} Tier selector {% endcomment %}
      <div class="bab__tiers" data-bab-tier-list role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'tier' -%}
            <div
              class="bab__tier"
              data-bab-tier
              data-quantity="{{ block.settings.quantity }}"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              <div class="bab__tier-head">
                <span class="bab__tier-name">{{ block.settings.name }}</span>
                {%- if block.settings.discount > 0 -%}
                  <span class="bab__badge bab__badge--success">{{ block.settings.discount }}% OFF</span>
                {%- endif -%}
              </div>
              <span class="bab__tier-qty">{{ block.settings.quantity }} BAGS</span>
              {%- if block.settings.perks != blank -%}
                <span class="bab__tier-perks">{{ block.settings.perks }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {% comment %} Selected count + unlock pill + progress bar {% endcomment %}
      <div class="bab__status">
        <span class="bab__selected-label">
          {{- section.settings.selected_label | default: 'SELECTED:' }}
          <span data-bab-selected-count>0</span>
        </span>
        <span class="bab__unlock-pill" data-bab-unlock-pill hidden></span>
      </div>

      <div class="bab__progress">
        <div class="bab__progress-track">
          <div class="bab__progress-fill" data-bab-progress-fill></div>
        </div>
        {%- liquid
          assign free_shipping_marked = false
          assign tier_count = 0
          for block in section.blocks
            if block.type == 'tier'
              assign tier_count = tier_count | plus: 1
            endif
          endfor
        -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'tier' -%}
            {%- assign pos = block.settings.quantity | times: 100.0 | divided_by: max_qty -%}
            <div
              class="bab__milestone"
              data-bab-milestone
              data-quantity="{{ block.settings.quantity }}"
              style="--milestone-pos: {{ pos }}%;"
            >
              <span class="bab__milestone-dot">
                <svg class="bab__milestone-check" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21 7L9 19l-5.5-5.5 1.41-1.41L9 16.17 19.59 5.59z"/></svg>
              </span>
              {%- if block.settings.free_shipping and free_shipping_marked == false -%}
                {%- assign free_shipping_marked = true -%}
                <span class="bab__milestone-label bab__badge bab__badge--success" data-bab-milestone-label>
                  {{- section.settings.free_shipping_label | default: 'FREE SHIPPING' -}}
                </span>
              {%- elsif forloop.last -%}
                <span class="bab__milestone-label bab__badge bab__badge--muted" data-bab-milestone-label>
                  {{- section.settings.max_savings_label | default: 'MAX SAVINGS' -}}
                </span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {% comment %} Selected picks strip {% endcomment %}
      <div class="bab__picks-wrap">
        <button type="button" class="bab__picks-arrow bab__picks-arrow--prev" data-bab-picks-prev aria-label="{{ 'content.pagination.previous' | t }}">&lsaquo;</button>
        <div class="bab__picks" data-bab-picks aria-live="polite"></div>
        <button type="button" class="bab__picks-arrow bab__picks-arrow--next" data-bab-picks-next aria-label="{{ 'content.pagination.next' | t }}">&rsaquo;</button>
      </div>
    </div>

    {% comment %} Right rail: subscribe & save, order summary, CTA {% endcomment %}
    <aside class="bab__rail" data-bab-rail>
      {%- if section.settings.enable_subscribe -%}
        <div class="bab__subscribe">
          <div class="bab__subscribe-head">
            <span class="bab__subscribe-title">{{ section.settings.subscribe_title }}</span>
            <button
              type="button"
              class="bab__toggle"
              data-bab-subscribe-toggle
              role="switch"
              aria-checked="false"
              aria-label="{{ section.settings.subscribe_title | escape }}"
            >
              <span class="bab__toggle-knob"></span>
            </button>
          </div>
          {%- if section.settings.subscribe_badge != blank -%}
            <span class="bab__badge bab__badge--accent">{{ section.settings.subscribe_badge }}</span>
          {%- endif -%}
          <ul class="bab__subscribe-benefits">
            {%- assign benefits = section.settings.subscribe_benefits | newline_to_br | split: '<br />' -%}
            {%- for benefit in benefits -%}
              {%- assign benefit_stripped = benefit | strip -%}
              {%- if benefit_stripped != blank -%}
                <li>
                  <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21 7L9 19l-5.5-5.5 1.41-1.41L9 16.17 19.59 5.59z"/></svg>
                  {{ benefit_stripped }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="bab__summary">
        <div class="bab__summary-row">
          <span>{{ section.settings.summary_packs_label | default: 'Packs Selected' }}</span>
          <span data-bab-summary-count>0</span>
        </div>
        <div class="bab__summary-row">
          <span>{{ section.settings.summary_price_label | default: 'Price per Pack' }}</span>
          <span data-bab-summary-per-pack>—</span>
        </div>
        {% comment %}
          Bundle Savings row — permanently hidden for now: this version has no
          bundle-level discount mechanism (Appstle tier plans are only allocated
          to the pack-size variants, not the single bag). Kept in the markup so
          a future quantity-discount implementation can re-enable it from JS.
        {% endcomment %}
        <div class="bab__summary-row" data-bab-summary-tier-row hidden>
          <span data-bab-summary-tier-label></span>
          <span data-bab-summary-tier-value></span>
        </div>
        <div class="bab__summary-row" data-bab-summary-plan-row hidden>
          <span data-bab-summary-plan-label></span>
          <span data-bab-summary-plan-value></span>
        </div>
        <div class="bab__summary-row">
          <span>{{ section.settings.summary_shipping_label | default: 'Shipping' }}</span>
          <span data-bab-summary-shipping>&mdash;</span>
        </div>
        <hr class="bab__summary-divider">
        <div class="bab__summary-row bab__summary-row--total">
          <span>{{ section.settings.summary_total_label | default: 'Total' }}</span>
          <span class="bab__summary-total">
            <span class="bab__summary-total-prices">
              <strong data-bab-summary-total>$0.00</strong>
              <s data-bab-summary-compare hidden></s>
            </span>
            <span class="bab__badge bab__badge--success" data-bab-summary-save hidden></span>
          </span>
        </div>
      </div>

      <button type="button" class="bab__cta" data-bab-add-to-cart disabled>
        <span data-bab-cta-text>{{ section.settings.cta_label | default: 'ADD TO CART' }}</span>
      </button>
    </aside>
  </div>

  {% comment %} Product grid {% endcomment %}
  <div class="bab__grid" data-bab-grid>
    {%- liquid
      # No collection picker: membership in the bundle's selling plan group is
      # the source of truth, scanned across the catalog (auto "all" collection).
      assign shown = 0
    -%}
    {%- for product in collections['all'].products limit: 50 -%}
        {%- liquid
          if shown >= section.settings.max_products
            break
          endif

          # The bundle is built from single bags: price, availability and the
          # selling plan all come from the single-bag variant (default "1 Pack").
          assign single_title = section.settings.single_variant_title | default: '1 Pack'
          assign variant = product.variants | where: 'title', single_title | first
          if variant == blank
            assign variant = product.selected_or_first_available_variant
          endif

          # Only products whose single-bag variant belongs to the bundle's plan
          # group are part of the Build-a-Box.
          assign bundle_group_id = ''
          for group in product.selling_plan_groups
            if group.name == plan_group_name
              assign bundle_group_id = group.id
              break
            endif
          endfor
          if bundle_group_id == ''
            continue
          endif
          assign in_bundle = false
          for alloc in variant.selling_plan_allocations
            if alloc.selling_plan_group_id == bundle_group_id
              assign in_bundle = true
              break
            endif
          endfor
          unless in_bundle
            continue
          endunless
          assign shown = shown | plus: 1

          assign card_accent = product.metafields.custom.color.value | default: accent
          assign notes = product.metafields.custom.card_flavor_notes.value | default: product.description | strip_html | truncatewords: 8

          # All Appstle selling plans allocated to the single-bag variant, one
          # per group (first plan = default delivery frequency). Group names
          # match tier names ("Mini Munch - 3 Bags" → 5%...), which is how JS
          # picks the tier plan for the achieved quantity. Today only "Single
          # Bag Plans" (0%) is allocated to 1 Pack — once the tier groups are
          # assigned to the single-bag variants in Appstle, the tiered prices
          # flow through here automatically.
          capture plans_json
            assign first_plan = true
            echo '['
            for group in product.selling_plan_groups
              assign group_plan = group.selling_plans | first
              for alloc in variant.selling_plan_allocations
                if alloc.selling_plan.id == group_plan.id
                  unless first_plan
                    echo ','
                  endunless
                  assign first_plan = false
                  echo '{"id":' | append: group_plan.id | append: ',"group":'
                  echo group.name | json
                  echo ',"price":' | append: alloc.price | append: '}'
                  break
                endif
              endfor
            endfor
            echo ']'
          endcapture

          assign sour_level = product.metafields.custom.sour_level.value
          assign card_badge = product.metafields.custom.card_badge.value
        -%}
        <div
          class="bab-card"
          data-bab-card
          style="--pc-accent: {{ card_accent }}; --card-accent: {{ card_accent }};"
          {% if shown > section.settings.mobile_initial_products %}
            data-bab-overflow
          {% endif %}
        >
          <div class="bab-card__media">
            {%- if product.featured_media -%}
              {{ product.featured_media | image_url: width: 600 | image_tag: loading: 'lazy', class: 'bab-card__image', widths: '300, 450, 600' }}
            {%- endif -%}
            {%- comment -%} Sour meter + card badge — shared with the storefront product cards (blocks/_product-card-gallery.liquid + snippets/product-badges-styles). {%- endcomment -%}
            {%- if sour_level != blank and sour_level > 0 -%}
              <div class="sour-meter" aria-label="{{ 'content.sour_level' | t: level: sour_level }}">
                <span class="sour-meter__label">{{ 'content.sour_label' | t }}</span>
                <span class="sour-meter__dots" aria-hidden="true">
                  {%- for i in (1..4) -%}
                    <span class="sour-meter__dot{% if i <= sour_level %} sour-meter__dot--filled{% endif %}"></span>
                  {%- endfor -%}
                </span>
              </div>
            {%- endif -%}
            {%- if card_badge != blank -%}
              <div
                class="product-badges product-badges--{{ settings.badge_position }}"
                style="--badge-border-radius: {{ settings.badge_corner_radius }}px; --badge-font-family: var(--font-{{ settings.badge_font_family }}--family); --badge-font-weight: var(--font-{{ settings.badge_font_family }}--weight); --badge-text-transform: {{ settings.badge_text_transform }};"
              >
                <div class="product-badges__badge product-badges__badge--rectangle product-badges__badge--{{ card_badge | handleize }}">
                  {{ card_badge }}
                </div>
              </div>
            {%- endif -%}
          </div>
          <div class="bab-card__info">
            <h3 class="bab-card__title">{{ product.title }}</h3>
            {%- if notes != blank -%}
              <p class="bab-card__notes">{{ notes }}</p>
            {%- endif -%}
          </div>
          <div class="bab-card__footer">
            <span class="bab-card__price" data-bab-card-price data-base="{{ variant.price }}">
              <span data-bab-card-price-now>{{ variant.price | money }}</span>
              <s class="bab-card__price-compare" data-bab-card-price-compare hidden></s>
            </span>
            <button
              type="button"
              class="bab-card__add"
              data-bab-add
              data-variant-id="{{ variant.id }}"
              data-product-id="{{ product.id }}"
              data-handle="{{ product.handle }}"
              data-title="{{ product.title | escape }}"
              data-price="{{ variant.price }}"
              data-image="{% if product.featured_media %}{{ product.featured_media | image_url: width: 300 }}{% endif %}"
              data-accent="{{ card_accent }}"
              data-plans="{{ plans_json | strip_newlines | escape }}"
              {% unless variant.available %}disabled{% endunless %}
            >
              {%- if variant.available -%}
                {{ section.settings.card_cta_label | default: 'ADD TO BUNDLE +' }}
              {%- else -%}
                {{ 'products.product.sold_out' | t | upcase }}
              {%- endif -%}
            </button>
          </div>
        </div>
      {%- endfor -%}
    {%- if shown == 0 -%}
      <div class="bab__empty">{{ 'onboarding.no_content' | t }}</div>
    {%- endif -%}
  </div>

  <button type="button" class="bab__see-more button" data-bab-see-more hidden>
    {{ section.settings.see_more_label | default: 'SEE MORE' }}
  </button>

  {% comment %} Floating picks bar — shown when the rail is off-screen {% endcomment %}
  <div class="bab__float" data-bab-float hidden>
    <div class="bab__float-picks-col">
      <div class="bab__float-head">
        <span class="bab__float-title">{{ section.settings.float_title | default: 'PACKS SELECTED' }}</span>
        <span class="bab__float-meta">
          <span class="bab__float-count" data-bab-float-count>0</span>
          <button type="button" class="bab__float-details" data-bab-float-details>
            {{ section.settings.float_details_label | default: '[See details]' }}
          </button>
        </span>
      </div>
      <div class="bab__picks bab__picks--float" data-bab-float-picks></div>
    </div>
    <div class="bab__float-actions">
      {%- if section.settings.enable_subscribe -%}
        <button type="button" class="bab__float-subscribe" data-bab-float-subscribe>
          <span data-bab-float-subscribe-label>{{ section.settings.subscribe_title }}</span>
          <span class="bab__toggle" data-bab-float-toggle role="switch" aria-checked="false">
            <span class="bab__toggle-knob"></span>
          </span>
        </button>
      {%- endif -%}
      <button type="button" class="bab__cta bab__cta--float" data-bab-float-add disabled>
        <span data-bab-float-cta-text>{{ section.settings.cta_label | default: 'ADD TO CART' }}</span>
      </button>
    </div>
  </div>
</build-a-box-section>

{%- comment -%} Shared card-badge styles (fan-fave / chaos-pick colour variants, positioning). {%- endcomment -%}
{% render 'product-badges-styles' %}

{% stylesheet %}
  .section-build-a-box {
    --bab-navy: #0b1b2b;
    --bab-slate: #5e7b93;
    --bab-track: #e3eef5;
    --bab-heading-font: var(--font-heading--family);
    --bab-body-font: var(--font-body--family);

    color: var(--bab-navy);

    /* Query container so the layout responds to the section's own width — not
       just the viewport — and reflows correctly when the cart drawer opens and
       squeezes the page. */
    container-type: inline-size;
    container-name: babwrap;
  }

  .section-build-a-box .bab__top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 414px);
    gap: 32px;
    align-items: start;
    margin-bottom: 48px;
  }

  .section-build-a-box .bab__main {
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }

  /* --- Banner: rocking boat scene ----------------------------------------- */
  /* The scene keeps the Figma artboard's 798×216 ratio at any width; every
     layer is positioned as a % of that box and text scales with container
     query units (cqw), so the composition is pixel-faithful at any size. */
  .section-build-a-box .bab__banner {
    position: relative;
    width: 100%;
    container-type: inline-size;
  }

  .section-build-a-box .bab__scene {
    position: relative;
    width: 100%;
    aspect-ratio: 798 / 216;
    border-radius: 30px;
    overflow: hidden;
    background-color: #dff1d8;
    isolation: isolate;
  }

  .section-build-a-box .bab__scene-topo {
    position: absolute;
    inset: 0;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    z-index: 1;
  }

  .section-build-a-box .bab__scene-water {
    position: absolute;
    left: 0;
    width: 100%;
    height: auto;
    display: block;
    pointer-events: none;
  }

  /* Back water starts 65/216 down; front wave lip at 153/216. */
  .section-build-a-box .bab__scene-water--back {
    top: 30.09%;
    z-index: 2;
    animation: bab-water-back 6.5s ease-in-out infinite;
  }

  .section-build-a-box .bab__scene-water--front {
    top: 70.83%;
    z-index: 4;
    animation: bab-water-front 5s ease-in-out infinite;
  }

  /* Boat box = 410/798 wide, offset 288/798 from the left, full scene height. */
  .section-build-a-box .bab__boat {
    position: absolute;
    left: 36.09%;
    top: 0;
    width: 51.38%;
    height: 100%;
    z-index: 3;
    transform-origin: 50% 82%;
    animation: bab-boat-rock 4.2s ease-in-out infinite;
    will-change: transform;
  }

  .section-build-a-box .bab__boat-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: auto;
    display: block;
  }

  /* Cargo well: selected product images stack down inside the hull bowl, so
     they read as snacks loaded into the boat (the front wave laps their base). */
  .section-build-a-box .bab__boat-cargo {
    position: absolute;
    left: 25%;
    right: 20%;
    bottom: 27%;
    height: 34%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    z-index: 1;
  }

  .section-build-a-box .bab-cargo {
    position: relative;
    flex: 0 0 auto;
    width: 15%;
    aspect-ratio: 1;
    margin-inline: -2.4%;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0.3cqw 0.8cqw rgba(11, 27, 43, 0.3);
    overflow: hidden;
    border: 0.35cqw solid #fff;
    animation: bab-cargo-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .section-build-a-box .bab-cargo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .section-build-a-box .bab-cargo--more {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0b1b2b;
    color: #fff;
    font-family: var(--bab-heading-font);
    font-size: 4cqw;
    line-height: 1;
  }

  /* --- Banner copy panel --------------------------------------------------- */
  .section-build-a-box .bab__scene-copy {
    position: absolute;
    left: 0.9%;
    top: 3.7%;
    width: 30%;
    height: 92.6%;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75cqw;
    padding: 2.6cqw 1.6cqw 1.9cqw;
    background: #0b1b2b;
    border: 2px dashed #fff;
    border-radius: 3.25cqw;
  }

  .section-build-a-box .bab__scene-title {
    margin: 0;
    align-self: flex-start;
    font-family: var(--bab-heading-font);
    font-weight: 400;
    font-size: 4cqw;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #fff;
  }

  .section-build-a-box .bab__scene-perks {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75cqw;
    width: 100%;
  }

  .section-build-a-box .bab__scene-perk {
    display: flex;
    align-items: center;
    gap: 0.7cqw;
  }

  .section-build-a-box .bab__scene-perk-num {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 3.6cqw;
    height: 3.6cqw;
    background: var(--bab-badge, #63b944) center / contain no-repeat;
    border-radius: 50%;
    font-family: var(--bab-heading-font);
    font-weight: 400;
    font-size: 1.85cqw;
    line-height: 1;
    color: #fff;
  }

  .section-build-a-box .bab__scene-perk-text {
    font-family: var(--bab-body-font);
    font-size: 1.5cqw;
    line-height: 1.15;
    color: #fff;
  }

  /* --- Banner animations --------------------------------------------------- */
  @keyframes bab-boat-rock {
    0%,
    100% {
      transform: translateY(0.6%) rotate(-1.5deg);
    }
    50% {
      transform: translateY(-1.6%) rotate(1.5deg);
    }
  }

  @keyframes bab-water-back {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(0.7%);
    }
  }

  @keyframes bab-water-front {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-1%);
    }
  }

  @keyframes bab-cargo-pop {
    from {
      transform: translateY(30%) scale(0.4);
      opacity: 0;
    }
    to {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-build-a-box .bab__boat,
    .section-build-a-box .bab__scene-water,
    .section-build-a-box .bab-cargo {
      animation: none !important;
    }
  }

  /* --- Tier selector ------------------------------------------------------ */
  /* auto-fit lets the cards wrap 2×2 when the cart drawer squeezes the page */
  .section-build-a-box .bab__tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
  }

  .section-build-a-box .bab__tier {
    display: flex;
    flex-direction: column;
    gap: 8px;
    border: 2px dashed #c8daff;
    border-radius: 15px;
    padding: 10px 15px 13px;
    background: transparent;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  /* Every reached tier stays fully highlighted (3/6/9 all stay blue at 9 bags). */
  .section-build-a-box .bab__tier[data-reached] {
    background: var(--bab-accent);
    color: #fff;
  }

  /* The stage currently being worked toward: half-strength highlight until
     the required bag count is reached. `data-next` wins over `data-reached`
     when both could apply (they can't: next.quantity is always > total). */
  .section-build-a-box .bab__tier[data-next] {
    background: color-mix(in srgb, var(--bab-accent) 50%, transparent);
    color: #fff;
  }

  /* Tier discounts are part of the subscription program — hide the % OFF
     badges when Subscribe & Save is off. */
  .section-build-a-box[data-subscribe='false'] .bab__tier .bab__badge--success {
    display: none;
  }

  .section-build-a-box .bab__tier-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 5px;
    flex-wrap: wrap;
  }

  .section-build-a-box .bab__tier-name {
    font-family: var(--bab-body-font);
    font-size: 16px;
    line-height: 1.3;
  }

  .section-build-a-box .bab__tier-qty {
    font-family: var(--bab-heading-font);
    font-size: 32px;
    line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
  }

  .section-build-a-box .bab__tier-perks {
    font-family: var(--bab-body-font);
    font-size: 12px;
    line-height: 1.3;
    opacity: 0.9;
  }

  /* --- Badges ------------------------------------------------------------- */
  .section-build-a-box .bab__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 2px 6px;
    border-radius: 20px;
    font-family: var(--bab-body-font);
    font-weight: 700;
    font-size: 12px;
    line-height: 1.4;
    white-space: nowrap;
    width: fit-content;
  }

  .section-build-a-box .bab__badge--success {
    background: var(--bab-success);
    color: #fff;
  }

  .section-build-a-box .bab__badge--accent {
    background: var(--bab-accent);
    color: #fff;
    padding: 5px 10px;
    font-family: var(--bab-heading-font);
    font-weight: 400;
    font-size: 14px;
  }

  .section-build-a-box .bab__badge--muted {
    background: #e8e8e8;
    border: 1px solid #cfcfcf;
    color: rgb(11 27 43 / 0.5);
  }

  /* --- Status + progress -------------------------------------------------- */
  .section-build-a-box .bab__status {
    display: flex;
    align-items: center;
    gap: 12px;
    min-height: 22px;
  }

  .section-build-a-box .bab__selected-label {
    font-family: var(--bab-body-font);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    flex: 0 0 auto;
  }

  .section-build-a-box .bab__unlock-pill {
    background: var(--bab-navy);
    color: #fff;
    font-family: var(--bab-body-font);
    font-weight: 700;
    font-size: 12px;
    padding: 3px 10px;
    border-radius: 20px;
    margin-inline: auto;
    text-align: center;
  }

  .section-build-a-box .bab__progress {
    position: relative;
    margin-bottom: 34px;
  }

  .section-build-a-box .bab__progress-track {
    height: 15px;
    border-radius: 999px;
    background: var(--bab-track);
    box-shadow: inset 0 2px 4px rgb(11 27 43 / 0.08);
    overflow: hidden;
  }

  .section-build-a-box .bab__progress-fill {
    height: 100%;
    width: 0%;
    border-radius: 999px;
    background: linear-gradient(to right, var(--bab-success), #62e474);
    transition: width 0.35s ease;
  }

  .section-build-a-box .bab__milestone {
    position: absolute;
    top: 50%;
    left: var(--milestone-pos, 0%);
    translate: -50% 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-build-a-box .bab__milestone-dot {
    translate: 0 -50%;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid #d5e4ee;
    box-shadow: 0 2px 6px rgb(11 27 43 / 0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    color: transparent;
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }

  .section-build-a-box .bab__milestone[data-reached] .bab__milestone-dot {
    background: var(--bab-success);
    border-color: #80d48c;
    color: #fff;
  }

  .section-build-a-box .bab__milestone-label {
    position: absolute;
    top: 18px;
    white-space: nowrap;
  }

  .section-build-a-box .bab__milestone:last-child .bab__milestone-label {
    translate: -30% 0;
  }

  /* --- Picks strip -------------------------------------------------------- */
  .section-build-a-box .bab__picks-wrap {
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section-build-a-box .bab__picks {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    flex: 1 1 auto;
    min-width: 0;
    padding-block: 4px;
  }

  .section-build-a-box .bab__picks::-webkit-scrollbar {
    display: none;
  }

  .section-build-a-box .bab__picks-arrow {
    flex: 0 0 auto;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid rgb(126 211 255 / 0.5);
    background: transparent;
    color: #009eed;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .section-build-a-box .bab__picks-arrow[disabled] {
    opacity: 0.5;
    cursor: default;
  }

  .section-build-a-box .bab-pick {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 105px;
    flex: 0 0 auto;
  }

  .section-build-a-box .bab-pick__media {
    aspect-ratio: 1;
    border: 2px solid var(--pick-accent, var(--bab-accent));
    border-radius: 10px;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--pick-accent, var(--bab-accent)) 13%, transparent),
      color-mix(in srgb, var(--pick-accent, var(--bab-accent)) 27%, transparent)
    );
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .section-build-a-box .bab-pick__media img {
    width: 82%;
    height: 82%;
    object-fit: contain;
  }

  .section-build-a-box .bab-pick__stepper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--pick-accent, var(--bab-accent));
    border-radius: 999px;
    padding: 3px;
  }

  .section-build-a-box .bab-pick__step {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 0;
    background: #e5edfc;
    color: var(--bab-navy);
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .section-build-a-box .bab-pick__qty {
    font-family: var(--bab-heading-font);
    font-size: 15px;
    color: #e5edfd;
  }

  .section-build-a-box .bab-pick--empty {
    aspect-ratio: 1;
    width: 105px;
    border: 2px dashed #cfcfcf;
    border-radius: 10px;
    background: #f7f7f7;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9aa7b1;
    font-size: 24px;
  }

  /* --- Right rail --------------------------------------------------------- */
  .section-build-a-box .bab__rail {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: sticky;
    top: 24px;
  }

  .section-build-a-box .bab__subscribe {
    background: var(--bab-accent-soft);
    border: 3px solid var(--bab-accent);
    border-radius: 26px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .section-build-a-box .bab__subscribe-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .section-build-a-box .bab__subscribe-title {
    font-family: var(--bab-heading-font);
    font-size: 32px;
    line-height: 0.9;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .section-build-a-box .bab__toggle {
    flex: 0 0 auto;
    width: 50px;
    height: 28px;
    border-radius: 999px;
    border: 0;
    background: #b8c9e8;
    position: relative;
    cursor: pointer;
    transition: background-color 0.2s ease;
    padding: 0;
    display: inline-block;
  }

  .section-build-a-box .bab__toggle-knob {
    position: absolute;
    top: 3px;
    left: 3px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #fff;
    transition: translate 0.2s ease;
  }

  .section-build-a-box .bab__toggle[aria-checked='true'] {
    background: var(--bab-accent);
  }

  .section-build-a-box .bab__toggle[aria-checked='true'] .bab__toggle-knob {
    translate: 22px 0;
  }

  .section-build-a-box .bab__subscribe-benefits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .section-build-a-box .bab__subscribe-benefits li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--bab-body-font);
    font-size: 16px;
    line-height: 1.3;
  }

  .section-build-a-box .bab__subscribe-benefits svg {
    color: var(--bab-accent);
    flex: 0 0 auto;
  }

  .section-build-a-box .bab__summary {
    background: var(--color-background, #fff);
    border: 3px dashed color-mix(in srgb, var(--bab-accent) 30%, transparent);
    border-radius: 26px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: var(--bab-body-font);
    font-size: 16px;
    line-height: 1.3;
  }

  .section-build-a-box .bab__summary-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }

  .section-build-a-box .bab__summary-divider {
    border: 0;
    border-top: 1px solid var(--bab-accent-soft);
    margin: 0;
    width: 100%;
  }

  .section-build-a-box .bab__summary-total {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 5px;
  }

  .section-build-a-box .bab__summary-total-prices {
    display: flex;
    align-items: baseline;
    gap: 7px;
  }

  .section-build-a-box .bab__summary-total-prices strong {
    font-family: var(--bab-heading-font);
    font-weight: 400;
    font-size: 32px;
    line-height: 0.9;
    letter-spacing: -0.01em;
  }

  .section-build-a-box .bab__summary-total-prices s {
    font-family: var(--bab-heading-font);
    font-size: 24px;
    opacity: 0.2;
  }

  /* --- CTA ---------------------------------------------------------------- */
  .section-build-a-box .bab__cta {
    width: 100%;
    background: var(--bab-cta-bg);
    box-shadow: 0 6px 0 var(--bab-cta-shadow);
    border: 0;
    border-radius: 999px;
    padding: 20px 34px 14px;
    font-family: var(--bab-heading-font);
    font-size: 20px;
    color: var(--bab-navy);
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
  }

  .section-build-a-box .bab__cta:hover:not([disabled]) {
    transform: translateY(2px);
    box-shadow: 0 4px 0 var(--bab-cta-shadow);
  }

  .section-build-a-box .bab__cta[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* --- Product grid ------------------------------------------------------- */
  /* auto-fit: 4 columns at full page width, gracefully drops to 3 when the
     cart drawer squeezes the page */
  .section-build-a-box .bab__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  .section-build-a-box .bab-card {
    background: #fff;
    border: 3px solid var(--pc-accent, var(--bab-accent));
    border-radius: 28px;
    box-shadow: 0 14px 15px color-mix(in srgb, var(--pc-accent, var(--bab-accent)) 22%, transparent);
    padding: 15px 15px 19px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .section-build-a-box .bab-card__media {
    position: relative;
    border-radius: 20px;
    background: linear-gradient(
      160deg,
      color-mix(in srgb, var(--pc-accent, var(--bab-accent)) 13%, transparent),
      color-mix(in srgb, var(--pc-accent, var(--bab-accent)) 27%, transparent)
    );
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 18px;
  }

  .section-build-a-box .bab-card__image {
    width: 85%;
    max-width: 250px;
    height: auto;
    aspect-ratio: 1;
    object-fit: contain;
  }

  /* Sour meter — mirrors the storefront product cards
     (blocks/_product-card-gallery.liquid). Kept in sync intentionally. */
  .section-build-a-box .sour-meter {
    position: absolute;
    top: var(--padding-sm);
    left: var(--padding-sm);
    z-index: var(--layer-flat);
    display: flex;
    align-items: start;
    gap: var(--gap-2xs);
    padding: 0.3125rem 0.625rem 0.05rem;
    background-color: var(--card-accent, var(--color-foreground));
    border-radius: 100px;
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.08);
  }

  .section-build-a-box .sour-meter__label {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgb(255 255 255);
    line-height: 1;
  }

  .section-build-a-box .sour-meter__dots {
    display: inline-flex;
    align-items: center;
    gap: 0.1875rem;
  }

  .section-build-a-box .sour-meter__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    border: 1.5px solid rgb(255 255 255);
  }

  .section-build-a-box .sour-meter__dot--filled {
    background-color: rgb(255 255 255);
  }

  @media only screen and (max-width: 749px) {
    .section-build-a-box .sour-meter {
      padding: 0.25rem 0.5rem 0.125rem;
      gap: 0.125rem;
    }

    .section-build-a-box .sour-meter__label {
      font-size: 0.625rem;
    }

    .section-build-a-box .sour-meter__dots {
      gap: 0.1rem;
    }
  }

  /* Pin the card badge (fan-fave / chaos-pick) to the top-right corner. The
     shared `.product-badges--*` inset relies on theme padding vars that inherit
     large values inside this card, which pushed the badge toward the centre —
     mirror the sour meter's simple corner inset instead. (The SOLD OUT stamp is
     part of the product image and stays centred.) */
  .section-build-a-box .bab-card__media .product-badges {
    top: var(--padding-sm);
    right: var(--padding-sm);
    bottom: auto;
    left: auto;
  }

  .section-build-a-box .bab-card__info {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding-inline: 6px;
  }

  .section-build-a-box .bab-card__title {
    font-family: var(--bab-heading-font);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0;
    color: var(--bab-navy);
  }

  .section-build-a-box .bab-card__notes {
    font-family: var(--bab-body-font);
    font-size: 16px;
    line-height: 1.3;
    letter-spacing: 0.02em;
    color: var(--bab-slate);
    margin: 0;
  }

  .section-build-a-box .bab-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-top: auto;
    padding-top: 8px;
    padding-inline: 6px 0;
  }

  .section-build-a-box .bab-card__price {
    font-family: var(--bab-heading-font);
    font-size: 24px;
    letter-spacing: -0.01em;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .section-build-a-box .bab-card__price-compare {
    font-size: 17px;
    opacity: 0.35;
  }

  .section-build-a-box .bab-card__add {
    background: var(--pc-accent, var(--bab-accent));
    color: #fff;
    border: 0;
    border-radius: 999px;
    padding: 13px 16px 10px;
    font-family: var(--bab-heading-font);
    font-size: 20px;
    line-height: 15px;
    cursor: pointer;
    white-space: nowrap;
    transition: filter 0.15s ease, transform 0.15s ease;
  }

  .section-build-a-box .bab-card__add:hover:not([disabled]) {
    filter: brightness(1.08);
  }

  .section-build-a-box .bab-card__add:active:not([disabled]) {
    transform: scale(0.97);
  }

  .section-build-a-box .bab-card__add[disabled] {
    filter: saturate(0.3);
    cursor: not-allowed;
  }

  .section-build-a-box .bab__empty {
    grid-column: 1 / -1;
    text-align: center;
    opacity: 0.6;
    padding: 24px 0;
  }

  .section-build-a-box .bab__see-more {
    display: none;
  }

  /* --- Floating bar ------------------------------------------------------- */
  .section-build-a-box .bab__float {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: var(--layer-overlay, 80);
    background: var(--color-background, #fff);
    border-top: 1px solid rgb(11 27 43 / 0.08);
    box-shadow: 0 -6px 24px rgb(11 27 43 / 0.12);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 14px clamp(16px, 4vw, 48px);
    transform: translateY(0);
    transition: transform 0.25s ease;
  }

  .section-build-a-box .bab__float[hidden] {
    display: none;
  }

  .section-build-a-box .bab__float-picks-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
    flex: 1 1 auto;
    max-width: 560px;
  }

  .section-build-a-box .bab__float-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .section-build-a-box .bab__float-title {
    font-family: var(--bab-heading-font);
    font-size: 16px;
    letter-spacing: -0.01em;
  }

  .section-build-a-box .bab__float-meta {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .section-build-a-box .bab__float-count {
    background: var(--bab-accent);
    color: #fff;
    font-family: var(--bab-body-font);
    font-size: 11px;
    width: 21px;
    height: 21px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .section-build-a-box .bab__float-details {
    background: none;
    border: 0;
    padding: 0;
    color: #009eed;
    font-family: var(--bab-body-font);
    font-size: 16px;
    cursor: pointer;
  }

  .section-build-a-box .bab__picks--float .bab-pick,
  .section-build-a-box .bab__picks--float .bab-pick--empty {
    width: 84px;
  }

  .section-build-a-box .bab__picks--float .bab-pick__step {
    width: 24px;
    height: 24px;
  }

  .section-build-a-box .bab__float-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 0 0 auto;
    width: 306px;
  }

  .section-build-a-box .bab__float-subscribe {
    background: var(--bab-accent-soft);
    border: 1px solid var(--bab-accent);
    border-radius: 999px;
    padding: 8px 12px 8px 17px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-family: var(--bab-heading-font);
    font-size: 20px;
    letter-spacing: -0.01em;
    color: var(--bab-navy);
    cursor: pointer;
    text-transform: uppercase;
  }

  .section-build-a-box .bab__cta--float {
    padding-block: 16px 11px;
  }

  /* --- Mobile ------------------------------------------------------------- */
  /* Container-driven reflow: when the section itself gets narrow — a small
     screen OR the cart drawer squeezing the page — collapse the two-column
     layout so the boat banner and content keep full width instead of being
     crushed into a sliver. Mirrors the viewport breakpoints below. */
  @container babwrap (max-width: 900px) {
    .section-build-a-box .bab__top {
      grid-template-columns: minmax(0, 1fr);
    }

    .section-build-a-box .bab__rail {
      position: static;
      order: 3;
    }

    .section-build-a-box .bab__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }
  }

  /* Boat banner layout switches on the banner's OWN width (it is a container),
     so it adopts the compact overlay whether the page is a phone or the cart
     drawer has narrowed it. Below ~600px the copy panel goes in-flow (driving
     the banner height) with the boat floating at the lower-right waterline. */
  @container (max-width: 600px) {
    .section-build-a-box .bab__scene {
      position: absolute;
      inset: 0;
      aspect-ratio: auto;
      height: 100%;
      z-index: 0;
    }

    /* Widen + centre the water so it always spans the full banner. max-width
       must be reset — the theme's global `img { max-width: 100% }` otherwise
       clamps this back to 100%, which (with the negative offset) left the right
       side of the scene bare. */
    .section-build-a-box .bab__scene-water--back,
    .section-build-a-box .bab__scene-water--front {
      top: auto;
      bottom: 0;
      left: -25%;
      width: 150%;
      max-width: none;
    }

    .section-build-a-box .bab__boat {
      left: auto;
      top: auto;
      right: -1%;
      bottom: 15%;
      width: 48%;
      height: auto;
      transform-origin: 55% 78%;
    }

    .section-build-a-box .bab__boat-img {
      position: static;
      width: 100%;
      height: auto;
    }

    .section-build-a-box .bab__scene-copy {
      position: relative;
      z-index: 2;
      width: 60%;
      height: auto;
      margin: 12px 0 12px 12px;
      align-items: flex-start;
      justify-content: center;
      gap: 7px;
      padding: 13px 14px 14px;
      border-radius: 18px;
    }

    .section-build-a-box .bab__scene-title {
      font-size: clamp(15px, 5.6cqw, 22px);
      line-height: 1;
    }

    .section-build-a-box .bab__scene-perks {
      gap: 7px;
    }

    .section-build-a-box .bab__scene-perk {
      gap: 7px;
      align-items: flex-start;
    }

    .section-build-a-box .bab__scene-perk-num {
      width: clamp(18px, 6.5cqw, 24px);
      height: clamp(18px, 6.5cqw, 24px);
      font-size: clamp(10px, 3.4cqw, 13px);
    }

    .section-build-a-box .bab__scene-perk-text {
      font-size: clamp(10.5px, 3.5cqw, 13px);
      line-height: 1.15;
    }
  }

  @media screen and (max-width: 989px) {
    .section-build-a-box .bab__top {
      grid-template-columns: minmax(0, 1fr);
    }

    .section-build-a-box .bab__rail {
      position: static;
      order: 3;
    }

    .section-build-a-box .bab__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }
  }

  @media screen and (max-width: 749px) {
    .section-build-a-box .bab__tiers {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 6px;
    }

    .section-build-a-box .bab__tier {
      padding: 8px 8px 10px;
    }

    .section-build-a-box .bab__tier-qty {
      font-size: 22px;
    }

    .section-build-a-box .bab__tier-name,
    .section-build-a-box .bab__tier-perks {
      font-size: 11px;
    }

    .section-build-a-box .bab__tier .bab__badge {
      font-size: 10px;
    }

    .section-build-a-box .bab__status {
      justify-content: center;
    }

    .section-build-a-box .bab__selected-label {
      display: none;
    }

    .section-build-a-box .bab__unlock-pill {
      margin-inline: 0;
    }

    .section-build-a-box .bab__picks-arrow {
      display: none;
    }

    .section-build-a-box .bab-pick,
    .section-build-a-box .bab-pick--empty {
      width: 84px;
    }

    .section-build-a-box .bab-pick__step {
      width: 24px;
      height: 24px;
    }

    /* Adjacent milestone labels collide on narrow screens — stagger the last
       one onto a second row. */
    .section-build-a-box .bab__progress {
      margin-bottom: 56px;
    }

    .section-build-a-box .bab__milestone-label {
      font-size: 10px;
    }

    .section-build-a-box .bab__milestone:last-child .bab__milestone-label {
      top: 40px;
      translate: -70% 0;
    }

    .section-build-a-box .bab-card {
      border-radius: 20px;
      border-width: 2px;
      padding: 10px 10px 14px;
    }

    .section-build-a-box .bab-card__title {
      font-size: 20px;
    }

    .section-build-a-box .bab-card__notes {
      font-size: 13px;
    }

    .section-build-a-box .bab-card__price {
      font-size: 18px;
    }

    .section-build-a-box .bab-card__add {
      font-size: 14px;
      padding: 8px 12px;
      width: 100%;
    }

    .section-build-a-box .bab-card__footer {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
    }

    .section-build-a-box .bab-card__price {
      align-self: flex-start;
    }

    /* SEE MORE collapse */
    .section-build-a-box[data-collapsed] .bab-card[data-bab-overflow] {
      display: none;
    }

    .section-build-a-box[data-collapsed] .bab__see-more {
      display: block;
      margin-top: 20px;
      width: 100%;
      background: transparent;
      border: 2px solid var(--bab-navy);
      border-radius: 999px;
      color: var(--bab-navy);
      font-family: var(--bab-heading-font);
      font-size: 18px;
      padding: 14px 0 10px;
    }

    /* Full stacked sticky: picks strip → subscribe pill → add-to-cart. */
    .section-build-a-box .bab__float {
      flex-direction: column;
      align-items: stretch;
      gap: 20px;
      padding: 13px 20px;
    }

    .section-build-a-box .bab__float-picks-col {
      display: flex;
      width: 100%;
      max-width: none;
      gap: 10px;
    }

    /* Picks scroll horizontally so the slots keep their size on narrow screens. */
    .section-build-a-box .bab__picks--float {
      overflow-x: auto;
    }

    .section-build-a-box .bab__float-actions {
      width: 100%;
      flex-direction: column;
      gap: 13px;
    }

    .section-build-a-box .bab__float-subscribe {
      width: 100%;
      height: 54px;
      font-size: 20px;
      padding: 8px 12px 8px 17px;
    }

    .section-build-a-box .bab__cta--float {
      width: 100%;
      font-size: 20px;
      padding: 20px 34px 14px;
    }
  }
{% endstylesheet %}

