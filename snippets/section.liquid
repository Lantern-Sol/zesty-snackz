{%- doc -%}
  Renders a wrapper section

  @param {section} section - The section object
  @param {string} children - The children of the section
  @param {string} section_id - The ID of the section
  @param {string} background_color - The background color of the section
{%- enddoc -%}

{%- liquid
  assign floating_media_type = section.settings.floating_media_type | default: 'image'
  assign has_floating_image = false
  assign has_floating_text = false
  if floating_media_type == 'image' and section.settings.floating_media != blank
    assign has_floating_image = true
  endif
  if floating_media_type == 'text' and section.settings.floating_media_text != blank
    assign has_floating_text = true
  endif
  assign has_floating_media = false
  if has_floating_image or has_floating_text
    assign has_floating_media = true
  endif

  assign skip_contrast = false
  if section.settings.background_media != blank and section.settings.background_media != 'none'
    assign skip_contrast = true
  endif
-%}
{% render 'contrast-override',
  background_color: background_color,
  section_id: section_id,
  skip_contrast: skip_contrast
%}

<div class="section-background color-custom-{{ section_id }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-custom-{{ section_id }}{% if has_floating_media %} section--has-floating-media{% endif %}{% if section.settings.floating_media_hide_mobile %} section--floating-media-hide-mobile{% endif %}"
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}

  style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}

    {% if section.settings.section_height != '' %}
     --section-preview-height: 600px;
     {% endif %}
  "
>
  <div class="custom-section-background">
    {% render 'background-media',
      background_media: section.settings.background_media,
      background_video: section.settings.video,
      background_video_position: section.settings.video_position,
      background_image: section.settings.background_image,
      background_image_mobile: section.settings.background_image_mobile,
      background_image_position: section.settings.background_image_position,
      background_image_position_y: section.settings.background_image_position_y
    %}
  </div>

  {%- if has_floating_media -%}
    {%- liquid
      # Map the 8 anchor values to independent vertical/horizontal tracks.
      case section.settings.floating_media_anchor
        when 'top-left'
          assign v = 'top'
          assign h = 'left'
        when 'top-center'
          assign v = 'top'
          assign h = 'center'
        when 'top-right'
          assign v = 'top'
          assign h = 'right'
        when 'center-left'
          assign v = 'center'
          assign h = 'left'
        when 'center-right'
          assign v = 'center'
          assign h = 'right'
        when 'bottom-left'
          assign v = 'bottom'
          assign h = 'left'
        when 'bottom-center'
          assign v = 'bottom'
          assign h = 'center'
        else
          assign v = 'bottom'
          assign h = 'right'
      endcase
    -%}
    {%- liquid
      # Mobile anchor: only apply when the user enabled mobile settings AND
      # explicitly picked a mobile anchor. Otherwise mobile uses the desktop anchor.
      assign v_mobile = ''
      assign h_mobile = ''
      if section.settings.use_floating_media_mobile_settings and section.settings.floating_media_anchor_mobile != blank
        case section.settings.floating_media_anchor_mobile
          when 'top-left'
            assign v_mobile = 'top'
            assign h_mobile = 'left'
          when 'top-center'
            assign v_mobile = 'top'
            assign h_mobile = 'center'
          when 'top-right'
            assign v_mobile = 'top'
            assign h_mobile = 'right'
          when 'center-left'
            assign v_mobile = 'center'
            assign h_mobile = 'left'
          when 'center-right'
            assign v_mobile = 'center'
            assign h_mobile = 'right'
          when 'bottom-left'
            assign v_mobile = 'bottom'
            assign h_mobile = 'left'
          when 'bottom-center'
            assign v_mobile = 'bottom'
            assign h_mobile = 'center'
          when 'bottom-right'
            assign v_mobile = 'bottom'
            assign h_mobile = 'right'
        endcase
      endif
    -%}
    {%- liquid
      assign width_rem = section.settings.floating_media_width | divided_by: 16.0
      assign offset_x_rem = section.settings.floating_media_offset_x | divided_by: 16.0
      assign offset_y_rem = section.settings.floating_media_offset_y | divided_by: 16.0
      assign width_mobile_rem = section.settings.floating_media_width_mobile | divided_by: 16.0
      assign offset_x_mobile_rem = section.settings.floating_media_offset_x_mobile | divided_by: 16.0
      assign offset_y_mobile_rem = section.settings.floating_media_offset_y_mobile | divided_by: 16.0
      assign text_pad_y_rem = section.settings.floating_media_text_padding_y | default: 0 | divided_by: 16.0
      assign text_pad_x_rem = section.settings.floating_media_text_padding_x | default: 0 | divided_by: 16.0
    -%}
    <div
      class="
        section-floating-media
        section-floating-media--{{ floating_media_type }}
        section-floating-media--v-{{ v }}
        section-floating-media--h-{{ h }}
        {% if section.settings.use_floating_media_mobile_settings %}section-floating-media--has-mobile-settings{% endif %}
        {% if v_mobile != blank %}section-floating-media--v-mobile-{{ v_mobile }}{% endif %}
        {% if h_mobile != blank %}section-floating-media--h-mobile-{{ h_mobile }}{% endif %}
      "
      style="
        --floating-media-width-desktop: {{ width_rem }}rem;
        --floating-media-offset-x-desktop: {{ offset_x_rem }}rem;
        --floating-media-offset-y-desktop: {{ offset_y_rem }}rem;
        --floating-media-rotation: {{ section.settings.floating_media_rotation }}deg;
        {% if section.settings.use_floating_media_mobile_settings %}
          --floating-media-width-mobile: {{ width_mobile_rem }}rem;
          --floating-media-offset-x-mobile: {{ offset_x_mobile_rem }}rem;
          --floating-media-offset-y-mobile: {{ offset_y_mobile_rem }}rem;
        {% endif %}
      "
      {% if has_floating_image %}aria-hidden="true"{% endif %}
    >
      {%- if has_floating_image -%}
        {{
          section.settings.floating_media
          | image_url: width: 800
          | image_tag: loading: 'lazy', widths: '120, 240, 480, 800', sizes: '(min-width: 750px) 500px, 240px', alt: section.settings.floating_media.alt
        }}
      {%- elsif has_floating_text -%}
        {%- assign floating_text_preset = section.settings.floating_media_text_preset | default: 'paragraph' -%}
        {%- assign floating_text_preset_mobile = section.settings.floating_media_text_preset_mobile -%}
        {%- assign floating_text_alignment = section.settings.floating_media_text_alignment | default: 'center' -%}
        <div
          class="section-floating-media__text {{ floating_text_preset }}{% if floating_text_preset_mobile != blank %} mobile-preset-{{ floating_text_preset_mobile }}{% endif %}"
          style="padding: {{ text_pad_y_rem }}rem {{ text_pad_x_rem }}rem; padding-top: {{ text_pad_y_rem | plus: 0.25 }}rem; --text-align: {{ floating_text_alignment }};"
        >
          {{ section.settings.floating_media_text }}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div
    class="border-style custom-section-content"
    style="{% render 'border-override', settings: section.settings %}"
  >
    {% if section.settings.toggle_overlay %}
      {% render 'overlay', settings: section.settings, layer: '0' %}
    {% endif %}

    <div
      class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
      data-testid="section-content"
    >
      {{ children }}
    </div>
  </div>
</div>

{% stylesheet %}
  .section-wrapper {
    --section-height-offset: 0px;
  }

  .section[data-shopify-visual-preview] {
    min-height: var(--section-preview-height);
    padding-top: 0;
  }

  .section[data-shopify-visual-preview] .custom-section-background {
    display: none;
  }

  body:has(#header-group > .header-section > #header-component[transparent]):not(
      :has(#header-group > .header-section + .shopify-section)
    )
    #MainContent
    > .section-wrapper:first-child {
    --section-height-offset: var(--header-group-height, 0);
  }

  .custom-section-background {
    grid-column: 1 / -1;
  }

  .custom-section-content {
    z-index: var(--layer-flat);
  }

  /* Floating media — spans full section, positioned absolutely above the content. */
  .section--has-floating-media {
    position: relative;
  }

  .section-floating-media {
    /* Edge offset = 0 for full-width; page-margin for page-width (overridden below). */
    --floating-media-edge-offset: 0px;
    /* Bind the unscoped vars (read by transforms / width below) to the desktop
       values. The @media rule at the bottom of this stylesheet rebinds them to
       the mobile values when use_floating_media_mobile_settings is on. We can't
       set them directly in the inline `style` attr because that would beat the
       media-query rule on mobile (custom-property cascade). */
    --floating-media-width: var(--floating-media-width-desktop, 7.5rem);
    --floating-media-offset-x: var(--floating-media-offset-x-desktop, 0);
    --floating-media-offset-y: var(--floating-media-offset-y-desktop, 0);
    position: absolute;
    grid-column: 1 / -1;
    width: var(--floating-media-width, 7.5rem);
    pointer-events: none;
    z-index: var(--layer-raised, 10);
    transform: translate(var(--floating-media-offset-x, 0), var(--floating-media-offset-y, 0))
      rotate(var(--floating-media-rotation, 0));
  }

  /* When the section is page-width, anchor horizontally to the page-width
     content edge rather than the viewport edge. `--util-page-margin-offset`
     is defined on `.section` and equals the left/right gutter width. */
  .section--page-width .section-floating-media {
    --floating-media-edge-offset: var(--util-page-margin-offset);
  }

  .section-floating-media img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Text variant hugs its content rather than using the width slider. */
  .section-floating-media.section-floating-media--text {
    width: max-content;
    max-width: 100%;
  }

  .section-floating-media__text {
    /* Drive base.css preset rules (.h1.h1, .paragraph, …) which read
       `color: var(--color, …)` — without this they fall through the invalid
       fallback chain and inherit from the section instead of the local
       color scheme set on this element. */
    --color: var(--color-foreground);
    display: block;
    width: 100%;
    background-color: var(--color-background);
    color: var(--color);
    text-align: var(--text-align, center);
    box-sizing: border-box;
    word-wrap: break-word;
  }

  @media screen and (max-width: 749px) {
    .section-floating-media__text.mobile-preset-paragraph {
      font-family: var(--font-paragraph--family);
      font-style: var(--font-paragraph--style);
      font-weight: var(--font-paragraph--weight);
      font-size: var(--font-paragraph--size);
      line-height: var(--font-paragraph--line-height);
      letter-spacing: 0;
      text-transform: var(--font-paragraph--case);
    }

    .section-floating-media__text.mobile-preset-h1 {
      font-family: var(--font-h1--family);
      font-style: var(--font-h1--style);
      font-weight: var(--font-h1--weight);
      font-size: var(--font-h1--size);
      line-height: var(--font-h1--line-height);
      letter-spacing: var(--font-h1--letter-spacing);
      text-transform: var(--font-h1--case);
    }

    .section-floating-media__text.mobile-preset-h2 {
      font-family: var(--font-h2--family);
      font-style: var(--font-h2--style);
      font-weight: var(--font-h2--weight);
      font-size: var(--font-h2--size);
      line-height: var(--font-h2--line-height);
      letter-spacing: var(--font-h2--letter-spacing);
      text-transform: var(--font-h2--case);
    }

    .section-floating-media__text.mobile-preset-h3 {
      font-family: var(--font-h3--family);
      font-style: var(--font-h3--style);
      font-weight: var(--font-h3--weight);
      font-size: var(--font-h3--size);
      line-height: var(--font-h3--line-height);
      letter-spacing: var(--font-h3--letter-spacing);
      text-transform: var(--font-h3--case);
    }

    .section-floating-media__text.mobile-preset-h4 {
      font-family: var(--font-h4--family);
      font-style: var(--font-h4--style);
      font-weight: var(--font-h4--weight);
      font-size: var(--font-h4--size);
      line-height: var(--font-h4--line-height);
      letter-spacing: var(--font-h4--letter-spacing);
      text-transform: var(--font-h4--case);
    }

    .section-floating-media__text.mobile-preset-h5 {
      font-family: var(--font-h5--family);
      font-style: var(--font-h5--style);
      font-weight: var(--font-h5--weight);
      font-size: var(--font-h5--size);
      line-height: var(--font-h5--line-height);
      letter-spacing: var(--font-h5--letter-spacing);
      text-transform: var(--font-h5--case);
    }

    .section-floating-media__text.mobile-preset-h6 {
      font-family: var(--font-h6--family);
      font-style: var(--font-h6--style);
      font-weight: var(--font-h6--weight);
      font-size: var(--font-h6--size);
      line-height: var(--font-h6--line-height);
      letter-spacing: var(--font-h6--letter-spacing);
      text-transform: var(--font-h6--case);
    }

    .section-floating-media__text.mobile-preset-h7 {
      font-family: var(--font-h7--family);
      font-style: var(--font-h7--style);
      font-weight: var(--font-h7--weight);
      font-size: var(--font-h7--size);
      line-height: var(--font-h7--line-height);
      letter-spacing: var(--font-h7--letter-spacing);
      text-transform: var(--font-h7--case);
    }
  }

  .section-floating-media--v-top {
    top: 0;
  }

  .section-floating-media--v-bottom {
    bottom: 0;
  }

  .section-floating-media--v-center {
    top: 50%;
    transform: translate(var(--floating-media-offset-x, 0), calc(-50% + var(--floating-media-offset-y, 0)))
      rotate(var(--floating-media-rotation, 0));
  }

  .section-floating-media--h-left {
    left: var(--floating-media-edge-offset);
  }

  .section-floating-media--h-right {
    right: var(--floating-media-edge-offset);
  }

  .section-floating-media--h-center {
    left: 50%;
    transform: translate(calc(-50% + var(--floating-media-offset-x, 0)), var(--floating-media-offset-y, 0))
      rotate(var(--floating-media-rotation, 0));
  }

  .section-floating-media--v-center.section-floating-media--h-center {
    transform: translate(calc(-50% + var(--floating-media-offset-x, 0)), calc(-50% + var(--floating-media-offset-y, 0)))
      rotate(var(--floating-media-rotation, 0));
  }

  @media screen and (max-width: 749px) {
    .section--floating-media-hide-mobile .section-floating-media {
      display: none;
    }

    /*
      Mobile floating-media overrides. When the user has enabled mobile-specific
      settings, rebind the unscoped vars to the mobile values; all transforms
      and the width property automatically pick them up. Falls back to the
      desktop value if a particular mobile var wasn't emitted.
    */
    .section-floating-media--has-mobile-settings {
      --floating-media-width: var(--floating-media-width-mobile, var(--floating-media-width-desktop, 7.5rem));
      --floating-media-offset-x: var(--floating-media-offset-x-mobile, var(--floating-media-offset-x-desktop, 0));
      --floating-media-offset-y: var(--floating-media-offset-y-mobile, var(--floating-media-offset-y-desktop, 0));
    }

    /*
      Mobile anchor: when one is set, reset the desktop top/bottom/left/right
      first (the desktop anchor classes set them), then apply the mobile anchor.
    */
    .section-floating-media:where(
      .section-floating-media--v-mobile-top,
      .section-floating-media--v-mobile-center,
      .section-floating-media--v-mobile-bottom
    ) {
      top: auto;
      bottom: auto;
    }

    .section-floating-media:where(
      .section-floating-media--h-mobile-left,
      .section-floating-media--h-mobile-center,
      .section-floating-media--h-mobile-right
    ) {
      left: auto;
      right: auto;
    }

    .section-floating-media--v-mobile-top {
      top: 0;
    }

    .section-floating-media--v-mobile-bottom {
      bottom: 0;
    }

    .section-floating-media--v-mobile-center {
      top: 50%;
      transform: translate(var(--floating-media-offset-x, 0), calc(-50% + var(--floating-media-offset-y, 0)))
        rotate(var(--floating-media-rotation, 0));
    }

    .section-floating-media--h-mobile-left {
      left: var(--floating-media-edge-offset);
    }

    .section-floating-media--h-mobile-right {
      right: var(--floating-media-edge-offset);
    }

    .section-floating-media--h-mobile-center {
      left: 50%;
      transform: translate(calc(-50% + var(--floating-media-offset-x, 0)), var(--floating-media-offset-y, 0))
        rotate(var(--floating-media-rotation, 0));
    }

    .section-floating-media--v-mobile-center.section-floating-media--h-mobile-center {
      transform: translate(calc(-50% + var(--floating-media-offset-x, 0)), calc(-50% + var(--floating-media-offset-y, 0)))
        rotate(var(--floating-media-rotation, 0));
    }
  }
{% endstylesheet %}
