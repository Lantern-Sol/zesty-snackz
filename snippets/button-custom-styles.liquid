{% doc %}
  Outputs scoped CSS custom properties for the button-custom style class and
  direct color overrides for the button-unstyled (link) style.

  @param {object} block_settings - The block's settings object
  @param {string} block_id - The block ID used to scope the CSS

  @example
  {% render 'button-custom-styles', block_settings: block_settings, block_id: block.id %}
{% enddoc %}

{% if block_settings.style_class == 'button-unstyled' and block_settings.link_text_color != blank %}
  {% style %}
    .button-unstyled--{{ block_id }},
    .email-signup__button.button-unstyled.button-unstyled--{{ block_id }} {
      color: rgb({{ block_settings.link_text_color.rgba }});
    }

    .button-unstyled--{{ block_id }}:hover,
    .email-signup__button.button-unstyled.button-unstyled--{{ block_id }}:hover {
      color: rgb({{ block_settings.link_text_color.rgb }} / var(--opacity-70));
    }
  {% endstyle %}
{% endif %}

{% if block_settings.style_class == 'button-custom' %}
  {%- assign effective_background_color = block_settings.custom_button_background
    | default: settings.palette_primary_button_background
  %}
  {%- assign effective_text_color = block_settings.custom_button_text
    | default: settings.palette_primary_button_text
  -%}
  {%- assign effective_border_color = block_settings.custom_button_border
    | default: settings.palette_primary_button_border
  -%}
  {%- if effective_background_color.alpha == 0 -%}
    {%- assign effective_focus_outline_color = effective_text_color -%}
  {%- else -%}
    {%- assign effective_focus_outline_color = effective_background_color -%}
  {%- endif -%}
  {%- capture hover_resolved -%}
    {% render 'resolve-custom-hover',
      base_bg: effective_background_color,
      base_text: effective_text_color,
      base_border: effective_border_color
    %}
  {%- endcapture -%}
  {%- assign hover_parts = hover_resolved | strip | split: '||' -%}
  {%- assign effective_hover_bg = hover_parts[0] -%}
  {%- assign effective_hover_text = hover_parts[1] -%}
  {%- assign effective_hover_border = hover_parts[2] -%}
  {%- if block_settings.custom_button_shadow_color != blank -%}
    {%- capture custom_shadow_color -%}rgb({{ block_settings.custom_button_shadow_color.rgba }}){%- endcapture -%}
  {%- else -%}
    {%- assign custom_shadow_color = 'var(--color-shadow)' -%}
  {%- endif -%}
  {% style %}
    .button-custom--{{ block_id }} {
      --button-background-color: rgb({{ effective_background_color.rgba }});
      --button-color: rgb({{ effective_text_color.rgba }});
      --button-border-color: rgb({{ effective_border_color.rgba }});
      --button-focus-outline-color: rgb({{ effective_focus_outline_color.rgb }});
      {%- if block_settings.custom_button_shadow_enabled %}
        box-shadow: {{ block_settings.custom_button_shadow_horizontal_offset | default: 0 }}px {{ block_settings.custom_button_shadow_vertical_offset | default: 0 }}px {{ block_settings.custom_button_shadow_blur_radius | default: 0 }}px {{ block_settings.custom_button_shadow_spread_radius | default: 0 }}px {{ custom_shadow_color }};
      {%- else %}
        /* Custom buttons own their shadow; don't inherit the primary's */
        box-shadow: none;
      {%- endif %}
      {%- if block_settings.custom_button_padding_enabled %}
        {%- liquid
          assign pad_block_start = block_settings.custom_button_padding_block_start | default: 16 | divided_by: 16.0
          assign pad_block_end = block_settings.custom_button_padding_block_end | default: 16 | divided_by: 16.0
          assign pad_inline_start = block_settings.custom_button_padding_inline_start | default: 24 | divided_by: 16.0
          assign pad_inline_end = block_settings.custom_button_padding_inline_end | default: 24 | divided_by: 16.0
          assign pad_block = pad_block_start | append: 'rem ' | append: pad_block_end | append: 'rem'
          assign pad_inline = pad_inline_start | append: 'rem ' | append: pad_inline_end | append: 'rem'
        -%}
        --button-padding-block: {{ pad_block }};
        --button-padding-inline: {{ pad_inline }};
        {%- if block_settings.custom_button_use_mobile_padding %}
          --mobile-button-padding-block: {{ block_settings.custom_button_padding_block_start_mobile | default: 16 | divided_by: 16.0 }}rem {{ block_settings.custom_button_padding_block_end_mobile | default: 16 | divided_by: 16.0 }}rem;
          --mobile-button-padding-inline: {{ block_settings.custom_button_padding_inline_start_mobile | default: 24 | divided_by: 16.0 }}rem {{ block_settings.custom_button_padding_inline_end_mobile | default: 24 | divided_by: 16.0 }}rem;
        {%- else %}
          {%- comment -%}
            The root-level mobile vars capture the theme's desktop values, so
            they must be re-declared here for the override to apply on mobile.
          {%- endcomment -%}
          --mobile-button-padding-block: {{ pad_block }};
          --mobile-button-padding-inline: {{ pad_inline }};
        {%- endif %}
      {%- endif %}
    }
    .button-custom--{{ block_id }}:hover {
      --button-background-color: {{ effective_hover_bg }};
      --button-color: {{ effective_hover_text }};
      --button-border-color: {{ effective_hover_border }};
    }
  {% endstyle %}
{% endif %}
