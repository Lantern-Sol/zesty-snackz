{% comment %}
  Wholesale Inquiry icon
  ----------------------
  Renders one of the fixed 24×24 line icons used in the info panel.
  Stroke uses currentColor so the surrounding text color drives it.

  @param name {string} - 'mail' | 'calendar' | 'warehouse'
{% endcomment %}

{%- case name -%}
  {%- when 'calendar' -%}
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation" aria-hidden="true">
      <rect x="3" y="5" width="18" height="16" rx="3" stroke="currentColor" stroke-width="1.5"/>
      <path d="M3 9.5h18M8 3.5v3M16 3.5v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  {%- when 'warehouse' -%}
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation" aria-hidden="true">
      <path d="M3 20V8.4a2 2 0 0 1 1.28-1.87l7-2.7a2 2 0 0 1 1.44 0l7 2.7A2 2 0 0 1 21 8.4V20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path d="M7 20v-6.5a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1V20M7 16h10M7 13.5h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M2 20h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" role="presentation" aria-hidden="true">
      <rect x="3" y="5.5" width="18" height="13" rx="3" stroke="currentColor" stroke-width="1.5"/>
      <path d="m5 8.5 5.6 4.2a2.3 2.3 0 0 0 2.8 0L19 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
{%- endcase -%}
